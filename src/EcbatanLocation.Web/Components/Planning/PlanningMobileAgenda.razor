@using EcbatanLocation.Application.DTOs
@{
    var culture = new System.Globalization.CultureInfo("fr-FR");
    var today = DateOnly.FromDateTime(DateTime.Today);

    // One row per reservation, grouped by arrival date — touch-friendly vertical agenda.
    var groups = Planning.Studios
        .SelectMany(s => s.Reservations.Select(r => (Studio: s.Studio, Reservation: r)))
        .GroupBy(x => x.Reservation.StartDate)
        .OrderBy(g => g.Key)
        .ToList();
}

@if (groups.Count == 0)
{
    <div class="hint" style="padding:24px;text-align:center">
        Aucune réservation pour cette période.
    </div>
}
else
{
    <div class="agenda">
        @foreach (var group in groups)
        {
            var isToday = group.Key == today;
            var occ = GetOccupation(group.Key);
            <div class="agenda-day @(isToday ? "today" : "")">
                <div class="agenda-date">
                    <span class="agenda-dow">@group.Key.ToString("ddd", culture)</span>
                    <span class="agenda-dom">@group.Key.Day</span>
                    <span class="agenda-mon">@group.Key.ToString("MMM", culture)</span>
                    @if (occ is not null)
                    {
                        <span class="day-occ"
                              style="background:@OccupancyPalette.Color(occ)"
                              title="@($"{occ.AvailablePlaces} places libres sur {occ.TotalCapacity}")"></span>
                    }
                </div>
                <div class="agenda-items">
                    @foreach (var item in group.OrderBy(x => x.Studio.Name))
                    {
                        var res = item.Reservation;
                        var statusClass = res.Status switch
                        {
                            ReservationStatus.Pending => "st-pending",
                            ReservationStatus.Accepted => "st-accepted",
                            ReservationStatus.Confirmed => "st-confirmed",
                            _ => ""
                        };
                        var statusLabel = res.Status switch
                        {
                            ReservationStatus.Pending => "Demande",
                            ReservationStatus.Accepted => "Acceptée",
                            ReservationStatus.Confirmed => "Confirmée",
                            _ => ""
                        };
                        var nights = res.EndDate.DayNumber - res.StartDate.DayNumber;

                        <div class="agenda-card booking @statusClass @(res.IsHypothetical ? "hypothetical" : "")"
                             role="button" tabindex="0"
                             @onclick="() => OnClick(res.Id)"
                             @onkeydown="(e) => OnKeyDown(e, res.Id)"
                             aria-label="@($"Réservation {res.TenantName}, {item.Studio.Name}, statut {statusLabel}{(res.IsHypothetical ? ", hypothétique" : "")}")">
                            <div class="agenda-card-head">
                                <span class="who">@res.TenantName</span>
                                <span class="badge @statusClass">@statusLabel</span>
                                @if (res.IsHypothetical)
                                {
                                    <span class="badge badge-hypothetical">Hypothétique</span>
                                }
                            </div>
                            <div class="agenda-card-meta">
                                <span class="studio">@item.Studio.Name</span>
                                <span>&bull;</span>
                                <span>@res.StartDate.ToString("dd/MM") → @res.EndDate.ToString("dd/MM")</span>
                                <span>&bull;</span>
                                <span>@nights nuit(s)</span>
                            </div>
                            <div class="agenda-card-foot">
                                <span class="owner">@res.OwnerName</span>
                                <span class="people">@res.PersonLines.Sum(l => l.AdultCount) ad. · @res.PersonLines.Sum(l => l.ChildrenUnder3Count) &lt;3a</span>
                            </div>
                            @if (res.LinkGroupIndex >= 0)
                            {
                                <span class="link-dot" style="background:@(LinkColors[res.LinkGroupIndex % LinkColors.Length])"></span>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public MonthlyPlanningDto Planning { get; set; } = default!;
    [Parameter] public MonthlyOccupationDto? Occupation { get; set; }
    [Parameter] public EventCallback<Guid> OnReservationClicked { get; set; }

    private static readonly string[] LinkColors = [
        "#e74c3c", "#3498db", "#2ecc71", "#f39c12",
        "#9b59b6", "#1abc9c", "#e67e22", "#34495e"
    ];

    private Dictionary<DateOnly, DailyOccupationDto>? _occupationByDay;

    protected override void OnParametersSet()
    {
        _occupationByDay = Occupation?.Days.ToDictionary(d => d.Date);
    }

    private DailyOccupationDto? GetOccupation(DateOnly date)
        => _occupationByDay is not null && _occupationByDay.TryGetValue(date, out var occ) ? occ : null;

    private async Task OnClick(Guid id) => await OnReservationClicked.InvokeAsync(id);

    private async Task OnKeyDown(KeyboardEventArgs e, Guid id)
    {
        if (e.Key is "Enter" or " ")
            await OnReservationClicked.InvokeAsync(id);
    }
}
