<div class="booking @GetStatusClass()" @onclick="OnClick"
     role="button" tabindex="0" @onkeydown="OnKeyDown"
     aria-label="@($"Réservation {Reservation.TenantName}, {Reservation.OwnerName}, statut {GetStatusLabel()}")">
    <div class="who">@Reservation.TenantName</div>
    <div class="owner">@Reservation.OwnerName</div>
    <div class="sub">
        <span>@Reservation.PersonLines.Sum(l => l.AdultCount) ad.</span>
        <span>@Reservation.PersonLines.Sum(l => l.ChildrenUnder3Count) &lt;3a</span>
        <span class="badge">@GetStatusLabel()</span>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public ReservationPlanningDto Reservation { get; set; } = default!;
    [Parameter] public EventCallback OnClick { get; set; }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " ")
            await OnClick.InvokeAsync();
    }

    private string GetStatusClass() => Reservation.Status switch
    {
        ReservationStatus.Pending => "st-pending",
        ReservationStatus.Accepted => "st-accepted",
        ReservationStatus.Confirmed => "st-confirmed",
        _ => ""
    };

    private string GetStatusLabel() => Reservation.Status switch
    {
        ReservationStatus.Pending => "Demande",
        ReservationStatus.Accepted => "Acceptée",
        ReservationStatus.Confirmed => "Confirmée",
        _ => ""
    };
}
