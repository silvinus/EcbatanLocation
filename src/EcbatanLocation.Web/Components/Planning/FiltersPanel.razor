<div class="field">
    <label>Mois</label>
    <input type="month" value="@($"{Year}-{Month:D2}")" @onchange="OnMonthInput" />
</div>

<div class="field">
    <label>Studio</label>
    <select value="@SelectedStudioId?.ToString()" @onchange="OnStudioInput">
        <option value="">Tous</option>
        @if (Studios is not null)
        {
            @foreach (var s in Studios)
            {
                <option value="@s.Id">@s.Name</option>
            }
        }
    </select>
</div>

<div class="field">
    <label>Statut</label>
    <select value="@SelectedStatus?.ToString()" @onchange="OnStatusInput">
        <option value="">Tous</option>
        <option value="Pending">Demande</option>
        <option value="Accepted">Accept&#233;e</option>
        <option value="Confirmed">Confirm&#233;e</option>
    </select>
</div>

<div class="field">
    <label>Propri&#233;taire</label>
    <select value="@SelectedOwnerId?.ToString()" @onchange="OnOwnerInput">
        <option value="">Tous</option>
        @if (Owners is not null)
        {
            @foreach (var o in Owners)
            {
                <option value="@o.Id">@o.Name</option>
            }
        }
    </select>
</div>

<div class="sep"></div>

<div class="hint">
    <b>S&#233;lection plage</b>
    <div class="chips mt-sm">
        <span class="chip muted">1er clic = d&#233;but</span>
        <span class="chip muted">2e clic = fin</span>
    </div>
    @if (RangeStart.HasValue)
    {
        <button class="btn full-width mt-md" @onclick="OnClearRange">R&#233;initialiser la plage</button>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<StudioDto>? Studios { get; set; }
    [Parameter] public IReadOnlyList<OwnerDto>? Owners { get; set; }
    [Parameter] public int Year { get; set; }
    [Parameter] public int Month { get; set; }
    [Parameter] public Guid? SelectedStudioId { get; set; }
    [Parameter] public ReservationStatus? SelectedStatus { get; set; }
    [Parameter] public Guid? SelectedOwnerId { get; set; }
    [Parameter] public DateOnly? RangeStart { get; set; }
    [Parameter] public EventCallback<(int year, int month)> OnYearMonthChanged { get; set; }
    [Parameter] public EventCallback<Guid?> OnStudioChanged { get; set; }
    [Parameter] public EventCallback<ReservationStatus?> OnStatusChanged { get; set; }
    [Parameter] public EventCallback<Guid?> OnOwnerChanged { get; set; }
    [Parameter] public EventCallback OnClearRange { get; set; }

    private async Task OnMonthInput(ChangeEventArgs e)
    {
        if (e.Value is string val && DateOnly.TryParse(val + "-01", out var date))
        {
            await OnYearMonthChanged.InvokeAsync((date.Year, date.Month));
        }
    }

    private async Task OnStudioInput(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        Guid? id = string.IsNullOrEmpty(val) ? null : Guid.Parse(val);
        await OnStudioChanged.InvokeAsync(id);
    }

    private async Task OnStatusInput(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        ReservationStatus? status = string.IsNullOrEmpty(val) ? null : Enum.Parse<ReservationStatus>(val);
        await OnStatusChanged.InvokeAsync(status);
    }

    private async Task OnOwnerInput(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        Guid? id = string.IsNullOrEmpty(val) ? null : Guid.Parse(val);
        await OnOwnerChanged.InvokeAsync(id);
    }
}
