@inject IMediator Mediator

<div class="modal-overlay" @onclick="OnCancel">
    <div class="modal-content modal-wide" role="dialog" aria-modal="true"
         aria-label="@(IsEdit ? "Modifier la réservation" : "Nouvelle réservation")" @onclick:stopPropagation="true">
        <div class="modal-hd">
            <h3>@(IsEdit ? "Modifier la réservation" : "Nouvelle réservation")</h3>
            <button class="x" @onclick="OnCancel">Fermer</button>
        </div>
        <div class="modal-bd">
            @if (_errorMessage is not null)
            {
                <div class="alert-error">@_errorMessage</div>
            }

            @if (_overlapWarning && !_isHypothetical)
            {
                <div class="alert-error">
                    @if (IsPerBedStudio)
                    {
                        <span>⚠ Plus assez de lits disponibles sur ces dates (@_availableBeds lit(s) / @_availableCapacity place(s) restant(s)).</span>
                    }
                    else
                    {
                        <span>⚠ Ce studio est déjà réservé sur ces dates. Veuillez choisir un autre créneau.</span>
                    }
                </div>
            }
            else if (_overlapWarning && _isHypothetical)
            {
                <div class="alert-info">
                    ℹ Réservation hypothétique : posée sur un créneau déjà occupé. Elle restera en « Demande » tant qu'elle ne sera pas promue.
                </div>
            }

            <div class="grid">
                <div class="field">
                    <label>Studio</label>
                    <select value="@_studioId" @onchange="OnStudioChanged">
                        <option value="">-- Choisir un studio --</option>
                        @foreach (var s in Studios.Where(s => !s.Unavailable))
                        {
                            <option value="@s.Id">@s.Name (@s.Capacity pers.@(s.HasKitchen ? ", cuisine" : "")@(!s.RentableAlone ? ", non louable seul" : ""))</option>
                        }
                    </select>
                    @if (!string.IsNullOrEmpty(_studioId) && _selectedStudio is not null && !_selectedStudio.RentableAlone)
                    {
                        <div class="field-hint warn">Ce studio ne peut être loué qu'avec un studio indépendant sur les mêmes dates.</div>
                    }
                </div>

                <div class="row">
                    <div class="field">
                        <label>Date d'arrivée</label>
                        <input type="date" value="@_startDate.ToString("yyyy-MM-dd")"
                               @onchange="OnStartDateChanged" />
                    </div>
                    <div class="field">
                        <label>Date de départ</label>
                        <input type="date" value="@_endDate.ToString("yyyy-MM-dd")"
                               @onchange="OnEndDateChanged" />
                    </div>
                </div>

                @if (_startDate < _endDate)
                {
                    <div class="hint">@NightCount nuit(s)</div>
                }
                @if (_startDate >= _endDate)
                {
                    <div class="field-hint warn">La date de départ doit être après la date d'arrivée.</div>
                }

                <div class="field">
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                        <input type="checkbox" checked="@_isHypothetical" @onchange="OnHypotheticalChanged" />
                        Réservation hypothétique
                    </label>
                    <div class="field-hint">
                        Permet de poser une réservation sur un créneau déjà pris par une demande ou une acceptation non confirmée.
                        Elle reste en « Demande » (ni acceptable ni confirmable) jusqu'à sa promotion.
                    </div>
                </div>

                @if (NeedsBedInput)
                {
                    <div class="field">
                        <label>Nombre de lits réservés</label>
                        <input type="number" min="1" max="@_selectedStudio!.NumberOfBeds" value="@_bedCount"
                               @onchange="OnBedCountChanged" />
                        <div class="field-hint">
                            @if (_availability is not null)
                            {
                                <span>@_availableBeds lit(s) libre(s) sur @_selectedStudio.NumberOfBeds — @_availableCapacity place(s) restante(s) sur ces dates.</span>
                            }
                            else
                            {
                                <span>Ce logement se loue au lit : @_selectedStudio.NumberOfBeds lit(s) au total.</span>
                            }
                        </div>
                    </div>
                }
                else if (IsPerBedStudio)
                {
                    <div class="field-hint">
                        Logement loué au lit (1 lit par personne).
                        @if (_availability is not null)
                        {
                            <span>@_availableBeds lit(s) libre(s) sur @_selectedStudio!.NumberOfBeds sur ces dates.</span>
                        }
                    </div>
                }

                @if (_selectedStudio is not null && !_selectedStudio.RentableAlone)
                {
                    <div class="field">
                        <label>Réservation parente</label>
                        @if (_loadingParents)
                        {
                            <div class="hint">Recherche des réservations parentes…</div>
                        }
                        else if (_compatibleParents.Count == 0)
                        {
                            <div class="field-hint warn">Aucune réservation parente compatible. Créez d'abord une réservation sur un studio indépendant.</div>
                        }
                        else
                        {
                            <select value="@(_parentReservationId?.ToString() ?? "")" @onchange="OnParentChanged">
                                <option value="">-- Choisir la réservation parente --</option>
                                @foreach (var p in _compatibleParents)
                                {
                                    <option value="@p.Id">@p.StudioName — @p.TenantName (@p.StartDate.ToString("dd/MM") - @p.EndDate.ToString("dd/MM"), @GetStatusLabel(p.Status))</option>
                                }
                            </select>
                        }
                    </div>
                }

                <div class="field">
                    <label>Nom du locataire</label>
                    <input @bind="_tenantName" placeholder="Nom complet du locataire" />
                </div>

                @* Person lines *@
                <div class="field">
                    <label>Personnes</label>
                    <div class="person-lines">
                        <div class="person-line-row person-line-head">
                            <div style="flex:2"></div>
                            <div style="flex:1" class="col-head">Adultes</div>
                            <div style="flex:1" class="col-head">Enfants &lt;3 ans</div>
                            @if (_personLines.Count > 1)
                            {
                                <span class="head-spacer"></span>
                            }
                        </div>
                        @for (int i = 0; i < _personLines.Count; i++)
                        {
                            var index = i;
                            var line = _personLines[index];
                            <div class="person-line-row">
                                <div class="field" style="flex:2">
                                    <select value="@line.ClientType" @onchange="e => OnLineTypeChanged(index, e)">
                                        @foreach (var ct in _allowedClientTypes)
                                        {
                                            <option value="@ct">@GetClientTypeLabel(ct)</option>
                                        }
                                    </select>
                                </div>
                                <div class="field" style="flex:1">
                                    <input type="number" min="0" value="@line.AdultCount"
                                           placeholder="Ad."
                                           @onchange="e => OnLineAdultChanged(index, e)" />
                                </div>
                                <div class="field" style="flex:1">
                                    <input type="number" min="0" value="@line.ChildrenCount"
                                           placeholder="Enf."
                                           @onchange="e => OnLineChildrenChanged(index, e)" />
                                </div>
                                @if (_personLines.Count > 1)
                                {
                                    <button class="x-small" @onclick="() => RemoveLine(index)" title="Supprimer">×</button>
                                }
                            </div>
                        }
                    </div>
                    <button class="btn" style="margin-top:6px;font-size:12px;padding:6px 10px" @onclick="AddLine">+ Ajouter un type</button>
                </div>

                @if (_selectedStudio is not null && TotalPersons > _selectedStudio.Capacity)
                {
                    <div class="field-hint warn">
                        Capacité dépassée : @TotalPersons personne(s) pour @_selectedStudio.Capacity place(s) max.
                    </div>
                }

                @if (_estimatedAmount.HasValue)
                {
                    <div class="estimation">
                        <span class="label">Montant estimé</span>
                        <span class="amount">@_estimatedAmount.Value.ToString("N2") €</span>
                    </div>
                }

                @if (_checkingOverlap)
                {
                    <div class="hint">Vérification de la disponibilité…</div>
                }
            </div>

            <div class="modal-actions">
                <button class="btn" @onclick="OnCancel">Annuler</button>
                <button class="btn primary" @onclick="Save" disabled="@(_saving || BlocksSave)">
                    @(_saving ? "Enregistrement..." : "Enregistrer")
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<StudioDto> Studios { get; set; } = [];
    [Parameter, EditorRequired] public Guid CurrentOwnerId { get; set; }
    [Parameter] public ReservationDetailDto? EditReservation { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private bool IsEdit => EditReservation is not null;

    private string _studioId = "";
    private DateOnly _startDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly _endDate = DateOnly.FromDateTime(DateTime.Today.AddDays(1));
    private string _tenantName = "";
    private List<PersonLineState> _personLines = [new(ClientType.Owner, 1, 0)];
    private decimal? _estimatedAmount;
    private string? _errorMessage;
    private bool _saving;
    private bool _overlapWarning;
    private bool _checkingOverlap;
    private bool _isHypothetical;
    private int _bedCount = 1;

    // A hypothetical reservation is deliberately allowed to overlap, so availability never blocks saving.
    private bool BlocksSave => _overlapWarning && !_isHypothetical;
    private EcbatanLocation.Application.Queries.CheckOverlap.OverlapCheckResult? _availability;
    private int _availableBeds;
    private int _availableCapacity;
    private StudioDto? _selectedStudio;

    private bool IsPerBedStudio => _selectedStudio?.RentalMode == RentalMode.PerBed;

    // Only ask for a bed count when beds are scarcer than capacity (e.g. a double bed for two).
    // When every bed holds one person (capacity == beds), beds are taken from the people count.
    private bool NeedsBedInput => IsPerBedStudio && _selectedStudio!.Capacity != _selectedStudio.NumberOfBeds;
    private int RequestedBeds => IsPerBedStudio
        ? (NeedsBedInput ? _bedCount : _personLines.Sum(l => l.AdultCount))
        : 1;
    private List<ClientType> _allowedClientTypes = [ClientType.Owner, ClientType.GuestWithPresence, ClientType.Acquaintance];

    private Guid? _parentReservationId;
    private List<ParentReservationOptionDto> _compatibleParents = [];
    private bool _loadingParents;

    private int NightCount => _endDate.DayNumber - _startDate.DayNumber;
    private int TotalPersons => _personLines.Sum(l => l.AdultCount + l.ChildrenCount);

    private CancellationTokenSource? _overlapCts;

    private class PersonLineState(ClientType clientType, int adultCount, int childrenCount)
    {
        public ClientType ClientType { get; set; } = clientType;
        public int AdultCount { get; set; } = adultCount;
        public int ChildrenCount { get; set; } = childrenCount;
    }

    protected override void OnParametersSet()
    {
        if (EditReservation is not null)
        {
            _studioId = EditReservation.Studio.Id.ToString();
            _startDate = EditReservation.StartDate;
            _endDate = EditReservation.EndDate;
            _tenantName = EditReservation.TenantName;
            _personLines = EditReservation.PersonLines
                .Select(pl => new PersonLineState(pl.ClientType, pl.AdultCount, pl.ChildrenUnder3Count))
                .ToList();
            _estimatedAmount = EditReservation.EstimatedAmount;
            _selectedStudio = Studios.FirstOrDefault(s => s.Id == EditReservation.Studio.Id);
            _parentReservationId = EditReservation.ParentReservationId;
            _bedCount = EditReservation.BedCount > 0 ? EditReservation.BedCount : 1;
            _isHypothetical = EditReservation.IsHypothetical;
            UpdateAllowedClientTypes();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && IsEdit && _selectedStudio is not null && !_selectedStudio.RentableAlone)
        {
            await LoadCompatibleParents();
            StateHasChanged();
        }
    }

    private void UpdateAllowedClientTypes()
    {
        ClientType? studioDefaultType = null;

        if (_selectedStudio is null)
        {
            _allowedClientTypes = [ClientType.Owner, ClientType.GuestWithPresence, ClientType.Acquaintance];
        }
        else
        {
            var name = _selectedStudio.Name.ToLowerInvariant();
            if (name.Contains("mobil"))
            {
                _allowedClientTypes = [ClientType.MobileHome, ClientType.Owner, ClientType.GuestWithPresence];
                studioDefaultType = ClientType.MobileHome;
            }
            else if (name.Contains("tente") || name.Contains("emplacement"))
            {
                _allowedClientTypes = [ClientType.Tent, ClientType.Owner, ClientType.GuestWithPresence];
                studioDefaultType = ClientType.Tent;
            }
            else
            {
                _allowedClientTypes = [ClientType.Owner, ClientType.GuestWithPresence, ClientType.Acquaintance];
            }
        }

        foreach (var line in _personLines)
        {
            if (!_allowedClientTypes.Contains(line.ClientType))
                line.ClientType = _allowedClientTypes[0];
        }

        if (studioDefaultType.HasValue && _personLines.Count > 0
            && _personLines[0].ClientType != studioDefaultType.Value)
        {
            _personLines[0].ClientType = studioDefaultType.Value;
        }
    }

    private async Task OnStudioChanged(ChangeEventArgs e)
    {
        _studioId = e.Value?.ToString() ?? "";
        _selectedStudio = Guid.TryParse(_studioId, out var sid)
            ? Studios.FirstOrDefault(s => s.Id == sid)
            : null;
        _parentReservationId = null;
        _compatibleParents = [];
        _bedCount = 1;
        _availability = null;
        UpdateAllowedClientTypes();
        await RefreshEstimateAndOverlap();
        if (_selectedStudio is not null && !_selectedStudio.RentableAlone)
            await LoadCompatibleParents();
    }

    private async Task OnStartDateChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var d))
            _startDate = d;
        await RefreshEstimateAndOverlap();
        if (_selectedStudio is not null && !_selectedStudio.RentableAlone)
            await LoadCompatibleParents();
    }

    private async Task OnEndDateChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var d))
            _endDate = d;
        await RefreshEstimateAndOverlap();
        if (_selectedStudio is not null && !_selectedStudio.RentableAlone)
            await LoadCompatibleParents();
    }

    private void OnParentChanged(ChangeEventArgs e)
    {
        _parentReservationId = Guid.TryParse(e.Value?.ToString(), out var pid) ? pid : null;
    }

    private async Task LoadCompatibleParents()
    {
        if (_startDate >= _endDate) return;

        _loadingParents = true;
        try
        {
            _compatibleParents = (await Mediator.Send(
                new EcbatanLocation.Application.Queries.GetCompatibleParents.GetCompatibleParentsQuery(
                    CurrentOwnerId, _startDate, _endDate,
                    IsEdit ? EditReservation!.Id : null))).ToList();

            if (_parentReservationId.HasValue && !_compatibleParents.Any(p => p.Id == _parentReservationId))
                _parentReservationId = null;
        }
        catch
        {
            _compatibleParents = [];
        }
        finally
        {
            _loadingParents = false;
        }
    }

    private async Task OnLineTypeChanged(int index, ChangeEventArgs e)
    {
        if (Enum.TryParse<ClientType>(e.Value?.ToString(), out var ct))
            _personLines[index].ClientType = ct;
        await EstimateAmount();
    }

    private async Task OnLineAdultChanged(int index, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var n))
            _personLines[index].AdultCount = Math.Max(0, n);
        RecomputeConflict();
        await EstimateAmount();
    }

    private void OnBedCountChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var n))
            _bedCount = Math.Max(1, n);
        RecomputeConflict();
    }

    private void OnHypotheticalChanged(ChangeEventArgs e)
    {
        _isHypothetical = e.Value is bool b && b;
    }

    private void RecomputeConflict()
    {
        if (_availability is null)
        {
            _overlapWarning = false;
            return;
        }

        if (_availability.IsPerBed)
        {
            _availableBeds = _availability.AvailableBeds;
            _availableCapacity = _availability.AvailableCapacity;
            _overlapWarning = RequestedBeds > _availableBeds
                              || _personLines.Sum(l => l.AdultCount) > _availableCapacity;
        }
        else
        {
            _overlapWarning = _availability.HasConflict;
        }
    }

    private async Task OnLineChildrenChanged(int index, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var n))
            _personLines[index].ChildrenCount = Math.Max(0, n);
        await EstimateAmount();
    }

    private void AddLine()
    {
        var usedTypes = _personLines.Select(l => l.ClientType).ToHashSet();
        var nextType = _allowedClientTypes
            .FirstOrDefault(t => !usedTypes.Contains(t), _allowedClientTypes[0]);
        _personLines.Add(new PersonLineState(nextType, 1, 0));
    }

    private async Task RemoveLine(int index)
    {
        _personLines.RemoveAt(index);
        await EstimateAmount();
    }

    private async Task RefreshEstimateAndOverlap()
    {
        await Task.WhenAll(EstimateAmount(), CheckOverlap());
    }

    private async Task EstimateAmount()
    {
        if (_startDate >= _endDate || _personLines.Sum(l => l.AdultCount) < 1)
        {
            _estimatedAmount = null;
            return;
        }

        try
        {
            var lines = _personLines
                .Select(l => new PersonLineDto(l.ClientType, l.AdultCount, l.ChildrenCount))
                .ToList();
            _estimatedAmount = await Mediator.Send(
                new EcbatanLocation.Application.Queries.EstimateAmount.EstimateAmountQuery(
                    _startDate, _endDate, lines));
        }
        catch
        {
            _estimatedAmount = null;
        }
    }

    private async Task CheckOverlap()
    {
        _overlapCts?.Cancel();
        _overlapCts = new CancellationTokenSource();
        var token = _overlapCts.Token;

        if (!Guid.TryParse(_studioId, out var studioId) || studioId == Guid.Empty
            || _startDate >= _endDate)
        {
            _availability = null;
            _overlapWarning = false;
            return;
        }

        _checkingOverlap = true;
        StateHasChanged();

        try
        {
            await Task.Delay(300, token);

            _availability = await Mediator.Send(
                new EcbatanLocation.Application.Queries.CheckOverlap.CheckOverlapQuery(
                    studioId, _startDate, _endDate,
                    IsEdit ? EditReservation!.Id : null),
                token);

            RecomputeConflict();
        }
        catch (OperationCanceledException) { }
        catch
        {
            _availability = null;
            _overlapWarning = false;
        }
        finally
        {
            _checkingOverlap = false;
        }
    }

    private async Task Save()
    {
        _errorMessage = null;
        _saving = true;

        try
        {
            if (!Guid.TryParse(_studioId, out var studioId) || studioId == Guid.Empty)
            {
                _errorMessage = "Veuillez sélectionner un studio.";
                return;
            }

            if (string.IsNullOrWhiteSpace(_tenantName))
            {
                _errorMessage = "Veuillez saisir le nom du locataire.";
                return;
            }

            if (_startDate >= _endDate)
            {
                _errorMessage = "La date de fin doit être après la date de début.";
                return;
            }

            if (_personLines.Sum(l => l.AdultCount) < 1)
            {
                _errorMessage = "Au moins 1 adulte est requis.";
                return;
            }

            if (BlocksSave)
            {
                _errorMessage = "Impossible d'enregistrer : le studio est déjà réservé sur ces dates.";
                return;
            }

            if (_selectedStudio is not null && !_selectedStudio.RentableAlone && _parentReservationId is null)
            {
                _errorMessage = "Veuillez sélectionner une réservation parente pour ce studio.";
                return;
            }

            var personLineDtos = _personLines
                .Where(l => l.AdultCount > 0 || l.ChildrenCount > 0)
                .Select(l => new PersonLineDto(l.ClientType, l.AdultCount, l.ChildrenCount))
                .ToList();

            var bedCount = RequestedBeds;

            if (IsEdit)
            {
                await Mediator.Send(new EcbatanLocation.Application.Commands.UpdateReservation.UpdateReservationCommand(
                    EditReservation!.Id, studioId, _startDate, _endDate,
                    _tenantName.Trim(), personLineDtos, _parentReservationId, bedCount, _isHypothetical));
            }
            else
            {
                await Mediator.Send(new EcbatanLocation.Application.Commands.CreateReservation.CreateReservationCommand(
                    studioId, CurrentOwnerId, _startDate, _endDate,
                    _tenantName.Trim(), personLineDtos, _parentReservationId, bedCount, _isHypothetical));
            }

            await OnSaved.InvokeAsync();
        }
        catch (UnauthorizedAccessException)
        {
            _errorMessage = "Vous devez être connecté pour effectuer cette action.";
        }
        catch (FluentValidation.ValidationException ex)
        {
            _errorMessage = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private static string GetClientTypeLabel(ClientType type) => type switch
    {
        ClientType.Owner => "Propriétaire",
        ClientType.GuestWithPresence => "Invité avec présence",
        ClientType.Acquaintance => "Connaissance",
        ClientType.MobileHome => "Mobil-home",
        ClientType.Tent => "Tente",
        _ => ""
    };

    private static string GetStatusLabel(ReservationStatus status) => status switch
    {
        ReservationStatus.Pending => "Demande",
        ReservationStatus.Accepted => "Acceptée",
        ReservationStatus.Confirmed => "Confirmée",
        _ => ""
    };
}
