@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Administration - Ecbatan Location</PageTitle>

<div class="admin-layout">
    <div class="admin-tabs">
        <a href="/" class="chip muted no-underline">&lt; Planning</a>
        <button class="chip @(_activeTab == "pricing" ? "active" : "muted")" @onclick='() => _activeTab = "pricing"'>
            Grille tarifaire
        </button>
        <button class="chip @(_activeTab == "studios" ? "active" : "muted")" @onclick='() => _activeTab = "studios"'>
            Studios
        </button>
        <button class="chip @(_activeTab == "users" ? "active" : "muted")" @onclick='() => SwitchToUsersTab()'>
            Utilisateurs
        </button>
        <button class="chip @(_activeTab == "report" ? "active" : "muted")" @onclick='() => SwitchToReportTab()'>
            Rapport
        </button>
    </div>

    @if (_activeTab == "pricing")
    {
        <div class="card">
            <div class="hd">
                <h2>Grille tarifaire</h2>
                <div class="toolbar">
                    <button class="btn-nav" @onclick="PreviousYear" aria-label="Année précédente">&lt;</button>
                    <span class="pill mono">@_pricingYear</span>
                    <button class="btn-nav" @onclick="NextYear" aria-label="Année suivante">&gt;</button>
                </div>
            </div>
            <div class="bd">
                @if (_loadingPricing)
                {
                    <div class="loading-indicator">Chargement des tarifs...</div>
                }
                else if (_pricingGrid is null)
                {
                    <div class="hint">
                        Aucune grille tarifaire pour @_pricingYear.
                        <button class="btn primary mt-sm" @onclick="CreateDefaultGrid">
                            Créer la grille @_pricingYear
                        </button>
                    </div>
                }
                else
                {
                    @if (_pricingSuccess is not null)
                    {
                        <div class="alert-success">@_pricingSuccess</div>
                    }
                    @if (_pricingError is not null)
                    {
                        <div class="alert-error">@_pricingError</div>
                    }

                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Type de client</th>
                                <th>Prix / jour / personne</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in _editLines)
                            {
                                <tr>
                                    <td>@GetClientTypeLabel(line.ClientType)</td>
                                    <td>
                                        <input type="number" step="0.50" min="0"
                                               @bind-value="line.Price"
                                               @bind-value:event="onchange"
                                               class="price-input" />
                                        <span class="price-unit">€</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div class="modal-actions">
                        <button class="btn" @onclick="ResetPricing">Annuler</button>
                        <button class="btn primary" @onclick="SavePricing" disabled="@_savingPricing">
                            @(_savingPricing ? "Enregistrement..." : "Enregistrer les tarifs")
                        </button>
                    </div>
                }
            </div>
        </div>
    }

    @if (_activeTab == "studios")
    {
        <div class="card">
            <div class="hd">
                <h2>Studios</h2>
                <button class="btn primary" @onclick="OpenCreateStudioModal">+ Nouveau studio</button>
            </div>
            <div class="bd">
                @if (_studiosSuccess is not null)
                {
                    <div class="alert-success">@_studiosSuccess</div>
                }
                @if (_studiosError is not null)
                {
                    <div class="alert-error">@_studiosError</div>
                }

                @if (_loadingStudios)
                {
                    <div class="loading-indicator">Chargement des studios...</div>
                }
                else if (_studios is not null)
                {
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Nom</th>
                                <th>Capacité</th>
                                <th>Location</th>
                                <th>Cuisine</th>
                                <th>Louable seul</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _studios)
                            {
                                <tr class="@(s.Unavailable ? "row-unavailable" : "")">
                                    <td><b>@s.Name</b></td>
                                    <td>@s.Capacity pers.</td>
                                    <td>
                                        @if (s.RentalMode == RentalMode.PerBed)
                                        {
                                            <span class="badge st-accepted">Au lit (@s.NumberOfBeds)</span>
                                        }
                                        else
                                        {
                                            <span class="badge">Logement</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @(s.HasKitchen ? "st-confirmed" : "")">
                                            @(s.HasKitchen ? "Oui" : "Non")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @(s.RentableAlone ? "st-confirmed" : "st-pending")">
                                            @(s.RentableAlone ? "Oui" : "Non")
                                        </span>
                                    </td>
                                    <td>
                                        @if (s.Unavailable)
                                        {
                                            <span class="badge st-pending">Indisponible</span>
                                        }
                                        else
                                        {
                                            <span class="badge st-confirmed">Disponible</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="detail-actions">
                                            <button class="btn" @onclick="() => OpenEditStudioModal(s)">Modifier</button>
                                            <button class="btn danger"
                                                    disabled="@s.HasReservations"
                                                    title="@(s.HasReservations ? "Ce studio a des réservations — supprimez-les d'abord" : "Supprimer ce studio")"
                                                    @onclick="() => OpenDeleteStudioConfirm(s)">
                                                Supprimer
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }

    @if (_activeTab == "users")
    {
        <div class="card">
            <div class="hd">
                <h2>Utilisateurs</h2>
                <button class="btn primary" @onclick="OpenCreateUserModal">+ Nouvel utilisateur</button>
            </div>
            <div class="bd">
                @if (_usersSuccess is not null)
                {
                    <div class="alert-success">@_usersSuccess</div>
                }
                @if (_usersError is not null)
                {
                    <div class="alert-error">@_usersError</div>
                }

                @if (_loadingUsers)
                {
                    <div class="loading-indicator">Chargement des utilisateurs...</div>
                }
                else if (_users is not null)
                {
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Nom</th>
                                <th>Email</th>
                                <th>Rôles</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in _users)
                            {
                                <tr>
                                    <td><b>@u.DisplayName</b></td>
                                    <td>@u.Email</td>
                                    <td>
                                        @foreach (var role in u.Roles)
                                        {
                                            <span class="badge @(role == "Admin" ? "st-accepted" : "st-confirmed")">@GetRoleLabel(role)</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="detail-actions">
                                            <button class="btn" @onclick="() => OpenEditUserModal(u)">Modifier</button>
                                            <button class="btn" @onclick="() => OpenResetPasswordConfirm(u)">Mot de passe</button>
                                            @if (u.UserId != _currentUserId)
                                            {
                                                <button class="btn danger"
                                                        disabled="@u.HasReservations"
                                                        title="@(u.HasReservations ? "Cet utilisateur a des réservations — supprimez-les d'abord" : "Supprimer cet utilisateur")"
                                                        @onclick="() => OpenDeleteConfirm(u)">
                                                    Supprimer
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }

    @if (_activeTab == "report")
    {
        <div class="card">
            <div class="hd">
                <h2>Rapport des réservations</h2>
            </div>
            <div class="bd">
                <div class="toolbar" style="gap:12px;flex-wrap:wrap;margin-bottom:12px">
                    <div class="detail-actions">
                        <button class="btn @(_reportMode == "month" ? "primary" : "")" @onclick='() => _reportMode = "month"'>Mois</button>
                        <button class="btn @(_reportMode == "year" ? "primary" : "")" @onclick='() => _reportMode = "year"'>Année</button>
                    </div>

                    <div class="toolbar">
                        <button class="btn-nav" @onclick="ReportPreviousPeriod" aria-label="Période précédente">&lt;</button>
                        @if (_reportMode == "month")
                        {
                            <span class="pill mono">@GetReportMonthName(_reportMonth) @_reportYear</span>
                        }
                        else
                        {
                            <span class="pill mono">@_reportYear</span>
                        }
                        <button class="btn-nav" @onclick="ReportNextPeriod" aria-label="Période suivante">&gt;</button>
                    </div>

                    <button class="btn primary" @onclick="LoadReport" disabled="@_loadingReport">
                        @(_loadingReport ? "Chargement..." : "Générer le rapport")
                    </button>

                    @if (_report is not null)
                    {
                        <a class="btn" href="@GetPdfUrl()" target="_blank">
                            Exporter PDF
                        </a>
                    }
                </div>

                @if (_reportError is not null)
                {
                    <div class="alert-error">@_reportError</div>
                }

                @if (_report is not null)
                {
                    @if (_report.Lines.Count == 0)
                    {
                        <div class="hint">Aucune réservation pour cette période.</div>
                    }
                    else
                    {
                        <div style="overflow-x:auto">
                            <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>Studio</th>
                                        <th>Locataire</th>
                                        <th>Propriétaire</th>
                                        <th>Dates</th>
                                        <th>Jours</th>
                                        <th>Détail personnes</th>
                                        <th>Montant</th>
                                        <th>Statut</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var line in _report.Lines)
                                    {
                                        <tr>
                                            <td><b>@line.StudioName</b></td>
                                            <td>@line.TenantName</td>
                                            <td>@line.OwnerName</td>
                                            <td class="mono">@line.StartDate.ToString("dd/MM") → @line.EndDate.ToString("dd/MM")</td>
                                            <td class="mono">@line.NumberOfDays</td>
                                            <td>
                                                @foreach (var pl in line.PersonLines)
                                                {
                                                    <div style="font-size:12px">
                                                        @pl.ClientTypeLabel : @pl.AdultCount ad.
                                                        @if (pl.ChildrenUnder3Count > 0)
                                                        {
                                                            <span>+ @pl.ChildrenUnder3Count enf.</span>
                                                        }
                                                        <span class="muted">× @pl.RatePerDay.ToString("0.00")€ = <b>@pl.LineAmount.ToString("0.00")€</b></span>
                                                    </div>
                                                }
                                            </td>
                                            <td class="mono"><b>@(line.TotalAmount.HasValue ? $"{line.TotalAmount:0.00} €" : "N/A")</b></td>
                                            <td>
                                                <span class="badge @GetReportStatusClass(line.Status)">@GetReportStatusLabel(line.Status)</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div style="margin-top:20px;display:flex;gap:20px;flex-wrap:wrap;align-items:center">
                            <div>
                                <span class="muted" style="font-size:12px">Réservations</span><br />
                                <b style="font-size:18px">@_report.Summary.TotalReservations</b>
                            </div>
                            <div>
                                <span class="muted" style="font-size:12px">Nuitées</span><br />
                                <b style="font-size:18px">@_report.Summary.TotalNights</b>
                            </div>
                            <div>
                                <span class="muted" style="font-size:12px">Montant total</span><br />
                                <b style="font-size:18px;color:var(--ok)">@_report.Summary.TotalAmount.ToString("0.00") €</b>
                            </div>
                        </div>

                        <div style="margin-top:16px;overflow-x:auto">
                            <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>Propriétaire</th>
                                        @foreach (var status in _report.Summary.ByStatus)
                                        {
                                            <th>
                                                <span class="badge @GetReportStatusClass(status.Status)">@GetReportStatusLabel(status.Status)</span>
                                            </th>
                                        }
                                        <th>Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var owner in _report.Summary.ByOwner)
                                    {
                                        <tr>
                                            <td><b>@owner.OwnerName</b><br /><span class="muted" style="font-size:11px">@owner.Count rés. / @owner.TotalNights nuits</span></td>
                                            @foreach (var status in _report.Summary.ByStatus)
                                            {
                                                var cell = _report.Summary.ByOwnerAndStatus
                                                    .FirstOrDefault(x => x.OwnerName == owner.OwnerName && x.Status == status.Status);
                                                <td class="mono">
                                                    @if (cell is not null)
                                                    {
                                                        <span>@cell.TotalAmount.ToString("0.00") €</span>
                                                        <br /><span class="muted" style="font-size:11px">@cell.Count rés.</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="muted">—</span>
                                                    }
                                                </td>
                                            }
                                            <td class="mono"><b>@owner.TotalAmount.ToString("0.00") €</b></td>
                                        </tr>
                                    }
                                    <tr>
                                        <td><b>Total</b></td>
                                        @foreach (var status in _report.Summary.ByStatus)
                                        {
                                            <td class="mono"><b>@status.TotalAmount.ToString("0.00") €</b><br /><span class="muted" style="font-size:11px">@status.Count rés.</span></td>
                                        }
                                        <td class="mono"><b style="color:var(--ok)">@_report.Summary.TotalAmount.ToString("0.00") €</b></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

@* ── Edit studio modal ── *@
@if (_showStudioModal)
{
    <div class="modal-overlay" @onclick="CloseStudioModal" @onclick:stopPropagation="false">
        <div class="modal-content modal-wide" role="dialog" aria-modal="true" @onclick:stopPropagation="true">
            <div class="modal-hd">
                <h3>@(_editingStudioId is null ? "Nouveau studio" : "Modifier le studio")</h3>
                <button class="x" @onclick="CloseStudioModal">&times;</button>
            </div>
            <div class="modal-bd">
                @if (_studioModalError is not null)
                {
                    <div class="alert-error">@_studioModalError</div>
                }
                <div class="grid">
                    <div class="field">
                        <label for="studio-name">Nom</label>
                        <input id="studio-name" type="text" @bind="_studioFormName" />
                    </div>
                    <div class="field">
                        <label for="studio-capacity">Capacité (personnes)</label>
                        <input id="studio-capacity" type="number" min="1" @bind="_studioFormCapacity" />
                    </div>
                    <div class="field">
                        <label>Options</label>
                        <div class="detail-actions">
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="_studioFormHasKitchen" /> Cuisine
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="_studioFormRentableAlone" /> Louable seul
                            </label>
                        </div>
                    </div>
                    <div class="field">
                        <label>Disponibilité</label>
                        <div class="detail-actions">
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="_studioFormUnavailable" /> Indisponible (bloque les réservations)
                            </label>
                        </div>
                    </div>
                    <div class="field">
                        <label>Mode de location</label>
                        <div class="detail-actions">
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="_studioFormPerBed" /> Louer au lit (plusieurs réservations simultanées)
                            </label>
                        </div>
                        <div class="field-hint">
                            Décoché : le logement se loue en entier. Coché : plusieurs personnes peuvent réserver des lits sur les mêmes dates.
                        </div>
                    </div>
                    @if (_studioFormPerBed)
                    {
                        <div class="field">
                            <label for="studio-beds">Nombre de lits</label>
                            <input id="studio-beds" type="number" min="1" max="@_studioFormCapacity" @bind="_studioFormNumberOfBeds" />
                            <div class="field-hint">Peut être inférieur à la capacité (ex. un lit double compte pour 1 lit / 2 personnes).</div>
                        </div>
                    }
                </div>
                <div class="modal-actions">
                    <button class="btn" @onclick="CloseStudioModal">Annuler</button>
                    <button class="btn primary" @onclick="SaveStudio" disabled="@_savingStudio">
                        @(_savingStudio ? "Enregistrement..." : "Enregistrer")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Delete studio confirmation modal ── *@
@if (_showDeleteStudioConfirm)
{
    <div class="modal-overlay" @onclick="CloseDeleteStudioConfirm" @onclick:stopPropagation="false">
        <div class="modal-content modal-wide" role="dialog" aria-modal="true" @onclick:stopPropagation="true">
            <div class="modal-hd">
                <h3>Confirmer la suppression</h3>
                <button class="x" @onclick="CloseDeleteStudioConfirm">&times;</button>
            </div>
            <div class="modal-bd">
                <p>Voulez-vous vraiment supprimer le studio <b>@_deleteStudioName</b> ?</p>
                <p class="hint">Cette action est irréversible.</p>
                <div class="modal-actions">
                    <button class="btn" @onclick="CloseDeleteStudioConfirm">Annuler</button>
                    <button class="btn danger" @onclick="ConfirmDeleteStudio" disabled="@_deletingStudio">
                        @(_deletingStudio ? "Suppression..." : "Supprimer")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Create / Edit user modal ── *@
@if (_showUserModal)
{
    <div class="modal-overlay" @onclick="CloseUserModal" @onclick:stopPropagation="false">
        <div class="modal-content modal-wide" role="dialog" aria-modal="true" @onclick:stopPropagation="true">
            <div class="modal-hd">
                <h3>@(_editingUserId is null ? "Nouvel utilisateur" : "Modifier l'utilisateur")</h3>
                <button class="x" @onclick="CloseUserModal">&times;</button>
            </div>
            <div class="modal-bd">
                @if (_userModalError is not null)
                {
                    <div class="alert-error">@_userModalError</div>
                }
                <div class="grid">
                    <div class="field">
                        <label for="user-name">Nom</label>
                        <input id="user-name" type="text" @bind="_userFormName" />
                    </div>
                    <div class="field">
                        <label for="user-email">Email</label>
                        <input id="user-email" type="email" @bind="_userFormEmail" />
                    </div>
                    <div class="field">
                        <label>Rôles</label>
                        <div class="detail-actions">
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="_userFormIsOwner" /> Propriétaire
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="_userFormIsAdmin" /> Administrateur
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-actions">
                    <button class="btn" @onclick="CloseUserModal">Annuler</button>
                    <button class="btn primary" @onclick="SaveUser" disabled="@_savingUser">
                        @(_savingUser ? "Enregistrement..." : "Enregistrer")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Generated password modal ── *@
@if (_showPasswordModal)
{
    <div class="modal-overlay" @onclick="ClosePasswordModal" @onclick:stopPropagation="false">
        <div class="modal-content modal-wide" role="dialog" aria-modal="true" @onclick:stopPropagation="true">
            <div class="modal-hd">
                <h3>Mot de passe généré</h3>
                <button class="x" @onclick="ClosePasswordModal">&times;</button>
            </div>
            <div class="modal-bd">
                <div class="alert-success">
                    Le mot de passe a été généré. Communiquez-le à l'utilisateur. Il ne sera plus affiché après fermeture.
                </div>
                <div class="estimation">
                    <span class="label">Mot de passe</span>
                    <span class="amount" style="font-family:var(--mono);letter-spacing:1px">@_generatedPassword</span>
                </div>
                <div class="modal-actions">
                    <button class="btn primary" @onclick="ClosePasswordModal">Fermer</button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Delete confirmation modal ── *@
@if (_showDeleteConfirm)
{
    <div class="modal-overlay" @onclick="CloseDeleteConfirm" @onclick:stopPropagation="false">
        <div class="modal-content modal-wide" role="dialog" aria-modal="true" @onclick:stopPropagation="true">
            <div class="modal-hd">
                <h3>Confirmer la suppression</h3>
                <button class="x" @onclick="CloseDeleteConfirm">&times;</button>
            </div>
            <div class="modal-bd">
                <p>Voulez-vous vraiment supprimer le compte de <b>@_deleteTargetName</b> (@_deleteTargetEmail) ?</p>
                <p class="hint">Cette action est irréversible.</p>
                <div class="modal-actions">
                    <button class="btn" @onclick="CloseDeleteConfirm">Annuler</button>
                    <button class="btn danger" @onclick="ConfirmDeleteUser" disabled="@_deletingUser">
                        @(_deletingUser ? "Suppression..." : "Supprimer")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Reset password confirmation modal ── *@
@if (_showResetConfirm)
{
    <div class="modal-overlay" @onclick="CloseResetConfirm" @onclick:stopPropagation="false">
        <div class="modal-content modal-wide" role="dialog" aria-modal="true" @onclick:stopPropagation="true">
            <div class="modal-hd">
                <h3>Régénérer le mot de passe</h3>
                <button class="x" @onclick="CloseResetConfirm">&times;</button>
            </div>
            <div class="modal-bd">
                <p>Régénérer un nouveau mot de passe pour <b>@_resetTargetName</b> ?</p>
                <p class="hint">L'ancien mot de passe sera invalidé.</p>
                <div class="modal-actions">
                    <button class="btn" @onclick="CloseResetConfirm">Annuler</button>
                    <button class="btn primary" @onclick="ConfirmResetPassword" disabled="@_resettingPassword">
                        @(_resettingPassword ? "Génération..." : "Régénérer")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string _activeTab = "pricing";

    private int _pricingYear = DateTime.Today.Year;
    private PricingGridDto? _pricingGrid;
    private List<EditablePricingLine> _editLines = [];
    private bool _loadingPricing = true;
    private bool _savingPricing;
    private string? _pricingSuccess;
    private string? _pricingError;

    private IReadOnlyList<StudioDto>? _studios;
    private bool _loadingStudios = true;
    private string? _studiosSuccess;
    private string? _studiosError;

    // Studio create/edit modal
    private bool _showStudioModal;
    private Guid? _editingStudioId;
    private string _studioFormName = "";
    private int _studioFormCapacity = 1;
    private bool _studioFormHasKitchen;
    private bool _studioFormRentableAlone;
    private bool _studioFormUnavailable;
    private bool _studioFormPerBed;
    private int _studioFormNumberOfBeds = 1;
    private bool _savingStudio;
    private string? _studioModalError;

    // Studio delete confirmation
    private bool _showDeleteStudioConfirm;
    private Guid? _deleteStudioId;
    private string? _deleteStudioName;
    private bool _deletingStudio;

    // ── Users tab state ──
    private IReadOnlyList<UserDto>? _users;
    private bool _loadingUsers;
    private string? _usersSuccess;
    private string? _usersError;
    private string? _currentUserId;

    // User form modal
    private bool _showUserModal;
    private string? _editingUserId;
    private string _userFormName = "";
    private string _userFormEmail = "";
    private bool _userFormIsOwner;
    private bool _userFormIsAdmin;
    private bool _savingUser;
    private string? _userModalError;

    // Password modal
    private bool _showPasswordModal;
    private string? _generatedPassword;

    // Delete confirmation
    private bool _showDeleteConfirm;
    private string? _deleteTargetUserId;
    private string? _deleteTargetName;
    private string? _deleteTargetEmail;
    private bool _deletingUser;

    // Reset password confirmation
    private bool _showResetConfirm;
    private string? _resetTargetUserId;
    private string? _resetTargetName;
    private bool _resettingPassword;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        await Task.WhenAll(LoadPricingGrid(), LoadStudios());
    }

    private async Task LoadPricingGrid()
    {
        _loadingPricing = true;
        _pricingSuccess = null;
        _pricingError = null;

        _pricingGrid = await Mediator.Send(
            new EcbatanLocation.Application.Queries.GetPricingGrid.GetPricingGridQuery(_pricingYear));

        if (_pricingGrid is not null)
        {
            _editLines = _pricingGrid.Lines
                .Select(l => new EditablePricingLine(l.ClientType, l.PricePerDayPerPerson))
                .ToList();
        }

        _loadingPricing = false;
    }

    private async Task LoadStudios()
    {
        _loadingStudios = true;
        _studiosSuccess = null;
        _studiosError = null;
        _studios = await Mediator.Send(new EcbatanLocation.Application.Queries.GetStudios.GetStudiosQuery());
        _loadingStudios = false;
    }

    private void OpenCreateStudioModal()
    {
        _editingStudioId = null;
        _studioFormName = "";
        _studioFormCapacity = 2;
        _studioFormHasKitchen = false;
        _studioFormRentableAlone = true;
        _studioFormUnavailable = false;
        _studioFormPerBed = false;
        _studioFormNumberOfBeds = 1;
        _studioModalError = null;
        _showStudioModal = true;
    }

    private void OpenEditStudioModal(StudioDto studio)
    {
        _editingStudioId = studio.Id;
        _studioFormName = studio.Name;
        _studioFormCapacity = studio.Capacity;
        _studioFormHasKitchen = studio.HasKitchen;
        _studioFormRentableAlone = studio.RentableAlone;
        _studioFormUnavailable = studio.Unavailable;
        _studioFormPerBed = studio.RentalMode == RentalMode.PerBed;
        _studioFormNumberOfBeds = studio.NumberOfBeds > 0 ? studio.NumberOfBeds : 1;
        _studioModalError = null;
        _showStudioModal = true;
    }

    private void CloseStudioModal() => _showStudioModal = false;

    private async Task SaveStudio()
    {
        _savingStudio = true;
        _studioModalError = null;

        try
        {
            var rentalMode = _studioFormPerBed ? RentalMode.PerBed : RentalMode.PerLodging;
            var numberOfBeds = _studioFormPerBed ? _studioFormNumberOfBeds : 0;

            if (_editingStudioId is null)
            {
                await Mediator.Send(
                    new EcbatanLocation.Application.Commands.CreateStudio.CreateStudioCommand(
                        _studioFormName, _studioFormCapacity,
                        _studioFormHasKitchen, _studioFormRentableAlone, _studioFormUnavailable,
                        rentalMode, numberOfBeds));

                _showStudioModal = false;
                _studiosSuccess = $"Studio « {_studioFormName} » créé.";
            }
            else
            {
                await Mediator.Send(
                    new EcbatanLocation.Application.Commands.UpdateStudio.UpdateStudioCommand(
                        _editingStudioId.Value, _studioFormName, _studioFormCapacity,
                        _studioFormHasKitchen, _studioFormRentableAlone, _studioFormUnavailable,
                        rentalMode, numberOfBeds));

                _showStudioModal = false;
                _studiosSuccess = $"Studio « {_studioFormName} » modifié.";
            }

            await LoadStudios();
        }
        catch (FluentValidation.ValidationException ex)
        {
            _studioModalError = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
        catch (Exception ex)
        {
            _studioModalError = ex.Message;
        }
        finally
        {
            _savingStudio = false;
        }
    }

    private void OpenDeleteStudioConfirm(StudioDto studio)
    {
        _deleteStudioId = studio.Id;
        _deleteStudioName = studio.Name;
        _showDeleteStudioConfirm = true;
    }

    private void CloseDeleteStudioConfirm() => _showDeleteStudioConfirm = false;

    private async Task ConfirmDeleteStudio()
    {
        _deletingStudio = true;
        try
        {
            await Mediator.Send(
                new EcbatanLocation.Application.Commands.DeleteStudio.DeleteStudioCommand(_deleteStudioId!.Value));

            _showDeleteStudioConfirm = false;
            _studiosSuccess = $"Studio « {_deleteStudioName} » supprimé.";
            await LoadStudios();
        }
        catch (Exception ex)
        {
            _showDeleteStudioConfirm = false;
            _studiosError = ex.Message;
        }
        finally
        {
            _deletingStudio = false;
        }
    }

    private async Task PreviousYear()
    {
        _pricingYear--;
        await LoadPricingGrid();
    }

    private async Task NextYear()
    {
        _pricingYear++;
        await LoadPricingGrid();
    }

    private void ResetPricing()
    {
        if (_pricingGrid is not null)
        {
            _editLines = _pricingGrid.Lines
                .Select(l => new EditablePricingLine(l.ClientType, l.PricePerDayPerPerson))
                .ToList();
        }
        _pricingSuccess = null;
        _pricingError = null;
    }

    private async Task SavePricing()
    {
        _savingPricing = true;
        _pricingSuccess = null;
        _pricingError = null;

        try
        {
            var lines = _editLines
                .Select(l => new EcbatanLocation.Application.Commands.UpdatePricingGrid.PricingLineInput(
                    l.ClientType, l.Price))
                .ToList();

            await Mediator.Send(
                new EcbatanLocation.Application.Commands.UpdatePricingGrid.UpdatePricingGridCommand(
                    _pricingYear, lines));

            await LoadPricingGrid();
            _pricingSuccess = "Grille tarifaire enregistrée.";
        }
        catch (UnauthorizedAccessException)
        {
            _pricingError = "Vous devez être connecté pour effectuer cette action.";
        }
        catch (FluentValidation.ValidationException ex)
        {
            _pricingError = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
        catch (Exception ex)
        {
            _pricingError = ex.Message;
        }
        finally
        {
            _savingPricing = false;
        }
    }

    private async Task CreateDefaultGrid()
    {
        _savingPricing = true;
        try
        {
            var defaultLines = new List<EcbatanLocation.Application.Commands.UpdatePricingGrid.PricingLineInput>
            {
                new(ClientType.Owner, 3.50m),
                new(ClientType.GuestWithPresence, 7.00m),
                new(ClientType.Acquaintance, 15.00m),
                new(ClientType.MobileHome, 12.00m),
                new(ClientType.Tent, 7.00m),
            };

            await Mediator.Send(
                new EcbatanLocation.Application.Commands.UpdatePricingGrid.UpdatePricingGridCommand(
                    _pricingYear, defaultLines));

            await LoadPricingGrid();
        }
        catch (Exception ex)
        {
            _pricingError = ex.Message;
        }
        finally
        {
            _savingPricing = false;
        }
    }

    private string GetClientTypeLabel(ClientType type) => type switch
    {
        ClientType.Owner => "Propriétaire (et familles)",
        ClientType.GuestWithPresence => "Invités avec présence",
        ClientType.Acquaintance => "Connaissances",
        ClientType.MobileHome => "Mobil-home",
        ClientType.Tent => "Tente",
        _ => type.ToString()
    };

    private class EditablePricingLine(ClientType clientType, decimal price)
    {
        public ClientType ClientType { get; } = clientType;
        public decimal Price { get; set; } = price;
    }

    // ── Report tab ──

    private string _reportMode = "month";
    private int _reportYear = DateTime.Today.Year;
    private int _reportMonth = DateTime.Today.Month;
    private bool _loadingReport;
    private string? _reportError;
    private ReservationReportDto? _report;

    private async Task SwitchToReportTab()
    {
        _activeTab = "report";
    }

    private async Task LoadReport()
    {
        _loadingReport = true;
        _reportError = null;
        _report = null;

        try
        {
            var month = _reportMode == "month" ? _reportMonth : (int?)null;
            _report = await Mediator.Send(
                new EcbatanLocation.Application.Queries.GetReservationReport.GetReservationReportQuery(
                    _reportYear, month));
        }
        catch (Exception ex)
        {
            _reportError = ex.Message;
        }
        finally
        {
            _loadingReport = false;
        }
    }

    private void ReportPreviousPeriod()
    {
        if (_reportMode == "month")
        {
            _reportMonth--;
            if (_reportMonth < 1) { _reportMonth = 12; _reportYear--; }
        }
        else
        {
            _reportYear--;
        }
        _report = null;
    }

    private void ReportNextPeriod()
    {
        if (_reportMode == "month")
        {
            _reportMonth++;
            if (_reportMonth > 12) { _reportMonth = 1; _reportYear++; }
        }
        else
        {
            _reportYear++;
        }
        _report = null;
    }

    private string GetPdfUrl()
    {
        var month = _reportMode == "month" ? $"&month={_reportMonth}" : "";
        return $"/api/report/pdf?year={_reportYear}{month}";
    }

    private static string GetReportMonthName(int month) => month switch
    {
        1 => "Janvier", 2 => "Février", 3 => "Mars", 4 => "Avril",
        5 => "Mai", 6 => "Juin", 7 => "Juillet", 8 => "Août",
        9 => "Septembre", 10 => "Octobre", 11 => "Novembre", 12 => "Décembre",
        _ => month.ToString()
    };

    private static string GetReportStatusLabel(ReservationStatus status) => status switch
    {
        ReservationStatus.Pending => "Demande",
        ReservationStatus.Accepted => "Acceptée",
        ReservationStatus.Confirmed => "Confirmée",
        _ => status.ToString()
    };

    private static string GetReportStatusClass(ReservationStatus status) => status switch
    {
        ReservationStatus.Pending => "st-pending",
        ReservationStatus.Accepted => "st-accepted",
        ReservationStatus.Confirmed => "st-confirmed",
        _ => ""
    };

    // ── Users tab ──

    private static string GetRoleLabel(string role) => role switch
    {
        "Owner" => "Propriétaire",
        "Admin" => "Administrateur",
        _ => role
    };

    private async Task SwitchToUsersTab()
    {
        _activeTab = "users";
        if (_users is null)
            await LoadUsers();
    }

    private async Task LoadUsers()
    {
        _loadingUsers = true;
        _usersSuccess = null;
        _usersError = null;

        try
        {
            _users = await Mediator.Send(
                new EcbatanLocation.Application.Queries.GetUsers.GetUsersQuery());
        }
        catch (Exception ex)
        {
            _usersError = ex.Message;
        }
        finally
        {
            _loadingUsers = false;
        }
    }

    private void OpenCreateUserModal()
    {
        _editingUserId = null;
        _userFormName = "";
        _userFormEmail = "";
        _userFormIsOwner = true;
        _userFormIsAdmin = false;
        _userModalError = null;
        _showUserModal = true;
    }

    private void OpenEditUserModal(UserDto user)
    {
        _editingUserId = user.UserId;
        _userFormName = user.DisplayName;
        _userFormEmail = user.Email;
        _userFormIsOwner = user.Roles.Contains("Owner");
        _userFormIsAdmin = user.Roles.Contains("Admin");
        _userModalError = null;
        _showUserModal = true;
    }

    private void CloseUserModal() => _showUserModal = false;

    private async Task SaveUser()
    {
        _savingUser = true;
        _userModalError = null;

        try
        {
            var roles = new List<string>();
            if (_userFormIsOwner) roles.Add("Owner");
            if (_userFormIsAdmin) roles.Add("Admin");

            if (roles.Count == 0)
            {
                _userModalError = "Au moins un rôle est requis.";
                return;
            }

            if (_editingUserId is null)
            {
                var result = await Mediator.Send(
                    new EcbatanLocation.Application.Commands.CreateUser.CreateUserCommand(
                        _userFormName, _userFormEmail, roles));

                _showUserModal = false;
                _generatedPassword = result.GeneratedPassword;
                _showPasswordModal = true;
                _usersSuccess = $"Utilisateur « {_userFormName} » créé.";
            }
            else
            {
                await Mediator.Send(
                    new EcbatanLocation.Application.Commands.UpdateUser.UpdateUserCommand(
                        _editingUserId, _userFormName, _userFormEmail, roles));

                _showUserModal = false;
                _usersSuccess = $"Utilisateur « {_userFormName} » modifié.";
            }

            await LoadUsers();
        }
        catch (FluentValidation.ValidationException ex)
        {
            _userModalError = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
        catch (Exception ex)
        {
            _userModalError = ex.Message;
        }
        finally
        {
            _savingUser = false;
        }
    }

    private void ClosePasswordModal()
    {
        _showPasswordModal = false;
        _generatedPassword = null;
    }

    private void OpenDeleteConfirm(UserDto user)
    {
        _deleteTargetUserId = user.UserId;
        _deleteTargetName = user.DisplayName;
        _deleteTargetEmail = user.Email;
        _showDeleteConfirm = true;
    }

    private void CloseDeleteConfirm() => _showDeleteConfirm = false;

    private async Task ConfirmDeleteUser()
    {
        _deletingUser = true;
        try
        {
            await Mediator.Send(
                new EcbatanLocation.Application.Commands.DeleteUser.DeleteUserCommand(_deleteTargetUserId!));

            _showDeleteConfirm = false;
            _usersSuccess = $"Utilisateur « {_deleteTargetName} » supprimé.";
            await LoadUsers();
        }
        catch (Exception ex)
        {
            _showDeleteConfirm = false;
            _usersError = ex.Message;
        }
        finally
        {
            _deletingUser = false;
        }
    }

    private void OpenResetPasswordConfirm(UserDto user)
    {
        _resetTargetUserId = user.UserId;
        _resetTargetName = user.DisplayName;
        _showResetConfirm = true;
    }

    private void CloseResetConfirm() => _showResetConfirm = false;

    private async Task ConfirmResetPassword()
    {
        _resettingPassword = true;
        try
        {
            var newPassword = await Mediator.Send(
                new EcbatanLocation.Application.Commands.ResetPassword.ResetPasswordCommand(_resetTargetUserId!));

            _showResetConfirm = false;
            _generatedPassword = newPassword;
            _showPasswordModal = true;
            _usersSuccess = $"Mot de passe de « {_resetTargetName} » régénéré.";
        }
        catch (Exception ex)
        {
            _showResetConfirm = false;
            _usersError = ex.Message;
        }
        finally
        {
            _resettingPassword = false;
        }
    }
}
