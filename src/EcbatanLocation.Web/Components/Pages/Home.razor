@page "/"
@inject IMediator Mediator
@rendermode InteractiveServer

<PageTitle>Ecbatan Location</PageTitle>

<div class="planning-page">
    <main class="card">
        <div class="hd">
            <div class="month-nav">
                <button class="btn-nav" @onclick="PreviousMonth" aria-label="Mois précédent">&lt;</button>
                <span class="month-label">@GetMonthLabel()</span>
                <button class="btn-nav" @onclick="NextMonth" aria-label="Mois suivant">&gt;</button>
            </div>
            <div class="toolbar">
                <button class="btn @(_showFilters ? "active" : null)" @onclick="ToggleFilters" aria-pressed="@_showFilters">
                    <span>&#9776; Filtres</span>
                    @if (ActiveFilterCount > 0)
                    {
                        <span class="count-badge">@ActiveFilterCount</span>
                    }
                </button>
                <div class="chips">
                    <button class="chip @(_viewMode == ViewMode.Month ? "active" : "muted")" aria-pressed="@(_viewMode == ViewMode.Month)" @onclick='() => _viewMode = ViewMode.Month'>Mois</button>
                    <button class="chip @(_viewMode == ViewMode.Week ? "active" : "muted")" aria-pressed="@(_viewMode == ViewMode.Week)" @onclick="SwitchToWeekView">Semaine</button>
                    <button class="chip @(_viewMode == ViewMode.List ? "active" : "muted")" aria-pressed="@(_viewMode == ViewMode.List)" @onclick='() => _viewMode = ViewMode.List'>Liste</button>
                </div>
                <div class="help-wrap">
                    <button class="btn-help @(_showHelp ? "active" : null)" @onclick="ToggleHelp" aria-label="Aide et légende" title="Aide et légende">?</button>
                    @if (_showHelp)
                    {
                        <div class="popover-backdrop" @onclick="CloseHelp"></div>
                        <div class="help-popover card">
                            <HelpPopover />
                        </div>
                    }
                </div>
                @if (_isAuthenticated)
                {
                    <button class="btn primary" @onclick="OpenCreateModal">+ Nouvelle réservation</button>
                }
            </div>
        </div>

        <div class="kpi-band-wrap">
            <OccupationBar SelectedDate="@_selectedDate"
                           RangeStart="@_rangeStart"
                           RangeEnd="@_rangeEnd"
                           Occupation="@_occupation"
                           RangeOccupation="@_rangeOccupation"
                           OnClearRange="ClearRange" />
        </div>

        <div class="bd planning">
            @if (_loading)
            {
                <div class="loading-indicator">Chargement du planning...</div>
            }
            else if (_planning is not null)
            {
                @if (_viewMode == ViewMode.Month)
                {
                    <PlanningGrid Planning="@_planning"
                                  Year="@Year"
                                  Month="@Month"
                                  SelectedDate="@_selectedDate"
                                  RangeStart="@_rangeStart"
                                  RangeEnd="@_rangeEnd"
                                  OnDaySelected="OnDaySelected"
                                  OnReservationClicked="OnReservationClicked" />
                }
                else if (_viewMode == ViewMode.Week)
                {
                    <PlanningWeekView Planning="@_planning"
                                      WeekStart="@_weekStart"
                                      SelectedDate="@_selectedDate"
                                      OnDaySelected="OnDaySelected"
                                      OnReservationClicked="OnReservationClicked" />
                }
                else if (_viewMode == ViewMode.List)
                {
                    <PlanningListView Planning="@_planning"
                                      OnReservationClicked="OnReservationClicked" />
                }
            }
        </div>
    </main>
</div>

@if (_showFilters)
{
    <div class="offcanvas-overlay" @onclick="CloseFilters"></div>
    <aside class="offcanvas card">
        <div class="hd">
            <h2>Filtres &amp; synthèse</h2>
            <button class="x" @onclick="CloseFilters" aria-label="Fermer">&#x2715;</button>
        </div>
        <div class="bd grid">
            <FiltersPanel Studios="@_studios"
                          Owners="@_owners"
                          Year="@Year"
                          Month="@Month"
                          SelectedStudioId="@SelectedStudioId"
                          SelectedStatus="@SelectedStatus"
                          SelectedOwnerId="@SelectedOwnerId"
                          RangeStart="@_rangeStart"
                          OnYearMonthChanged="OnYearMonthChanged"
                          OnStudioChanged="OnStudioChanged"
                          OnStatusChanged="OnStatusChanged"
                          OnOwnerChanged="OnOwnerChanged"
                          OnClearRange="ClearRange" />
        </div>
    </aside>
}

@if (_selectedReservation is not null && !_showFormModal && !_showDeleteModal)
{
    <ReservationDetailModal Reservation="@_selectedReservation"
                            IsAuthenticated="@_isAuthenticated"
                            CurrentOwnerName="@_currentOwner?.Name"
                            OnClose="CloseDetailModal"
                            OnEdit="OpenEditModal"
                            OnDelete="OpenDeleteModal"
                            OnStatusChanged="OnReservationStatusChanged"
                            OnReservationClicked="OnReservationClicked" />
}

@if (_showFormModal)
{
    <ReservationFormModal Studios="@(_studios ?? [])"
                          CurrentOwnerId="@(_currentOwner?.Id ?? Guid.Empty)"
                          EditReservation="@_editingReservation"
                          OnSaved="OnFormSaved"
                          OnCancel="CloseFormModal" />
}

@if (_showDeleteModal && _deletingReservation is not null)
{
    <DeleteConfirmModal Reservation="@_deletingReservation"
                        OnDeleted="OnDeleted"
                        OnCancel="CloseDeleteModal" />
}
