@page "/change-password"
@attribute [Authorize]
@using Microsoft.AspNetCore.Identity
@using EcbatanLocation.Infrastructure.Identity
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager

<PageTitle>Changer le mot de passe - Ecbatan Location</PageTitle>

<div class="login-wrap">
    <div class="card login-card">
        <div class="hd"><h2>Changer le mot de passe</h2></div>
        <div class="bd">
            @if (!string.IsNullOrEmpty(_successMessage))
            {
                <div class="alert-success">@_successMessage</div>
            }
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert-error">@_errorMessage</div>
            }

            <EditForm Model="Input" method="post" OnValidSubmit="HandleSubmit" FormName="change-password">
                <DataAnnotationsValidator />

                <div class="grid">
                    <div class="field">
                        <label for="current">Mot de passe actuel</label>
                        <input id="current" type="password" name="Input.CurrentPassword"
                               value="@Input.CurrentPassword"
                               @onchange="e => Input.CurrentPassword = e.Value?.ToString() ?? string.Empty" />
                        <ValidationMessage For="() => Input.CurrentPassword" />
                    </div>
                    <div class="field">
                        <label for="newpwd">Nouveau mot de passe</label>
                        <input id="newpwd" type="password" name="Input.NewPassword"
                               value="@Input.NewPassword"
                               @onchange="e => Input.NewPassword = e.Value?.ToString() ?? string.Empty" />
                        <ValidationMessage For="() => Input.NewPassword" />
                    </div>
                    <div class="field">
                        <label for="confirm">Confirmer le nouveau mot de passe</label>
                        <input id="confirm" type="password" name="Input.ConfirmPassword"
                               value="@Input.ConfirmPassword"
                               @onchange="e => Input.ConfirmPassword = e.Value?.ToString() ?? string.Empty" />
                        <ValidationMessage For="() => Input.ConfirmPassword" />
                    </div>
                    <button type="submit" class="btn primary full-width" disabled="@_submitting">
                        @(_submitting ? "Modification..." : "Modifier le mot de passe")
                    </button>
                </div>
            </EditForm>

            <div class="hint mt-md center-text">
                Le mot de passe doit contenir au moins 8 caractères, une majuscule, une minuscule et un chiffre.
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private ChangePasswordModel Input { get; set; } = default!;

    private string? _errorMessage;
    private string? _successMessage;
    private bool _submitting;

    protected override void OnInitialized()
    {
        Input ??= new();
    }

    private async Task HandleSubmit()
    {
        _errorMessage = null;
        _successMessage = null;
        _submitting = true;

        try
        {
            if (Input.NewPassword != Input.ConfirmPassword)
            {
                _errorMessage = "Les mots de passe ne correspondent pas.";
                return;
            }

            var user = await UserManager.GetUserAsync(HttpContext.User);
            if (user is null)
            {
                _errorMessage = "Utilisateur introuvable.";
                return;
            }

            var result = await UserManager.ChangePasswordAsync(user, Input.CurrentPassword, Input.NewPassword);

            if (result.Succeeded)
            {
                _successMessage = "Mot de passe modifié avec succès.";
                Input = new();
            }
            else
            {
                _errorMessage = string.Join(" ", result.Errors.Select(e => e.Code switch
                {
                    "PasswordMismatch" => "Le mot de passe actuel est incorrect.",
                    "PasswordTooShort" => "Le nouveau mot de passe est trop court (minimum 8 caractères).",
                    "PasswordRequiresDigit" => "Le mot de passe doit contenir au moins un chiffre.",
                    "PasswordRequiresLower" => "Le mot de passe doit contenir au moins une minuscule.",
                    "PasswordRequiresUpper" => "Le mot de passe doit contenir au moins une majuscule.",
                    _ => e.Description
                }));
            }
        }
        finally
        {
            _submitting = false;
        }
    }

    private sealed class ChangePasswordModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Le mot de passe actuel est requis.")]
        public string CurrentPassword { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Le nouveau mot de passe est requis.")]
        [System.ComponentModel.DataAnnotations.MinLength(8, ErrorMessage = "Minimum 8 caractères.")]
        public string NewPassword { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "La confirmation est requise.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
