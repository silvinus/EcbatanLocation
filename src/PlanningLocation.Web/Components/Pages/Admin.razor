@page "/admin"
@attribute [Authorize]
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Administration - Planning de location</PageTitle>

<div class="admin-layout">
    <div class="admin-tabs">
        <button class="chip @(_activeTab == "pricing" ? "active" : "muted")" @onclick='() => _activeTab = "pricing"'>
            Grille tarifaire
        </button>
        <button class="chip @(_activeTab == "studios" ? "active" : "muted")" @onclick='() => _activeTab = "studios"'>
            Studios
        </button>
    </div>

    @if (_activeTab == "pricing")
    {
        <div class="card">
            <div class="hd">
                <h2>Grille tarifaire</h2>
                <div style="display:flex;gap:8px;align-items:center">
                    <button class="btn-nav" @onclick="PreviousYear">&lt;</button>
                    <span class="pill mono">@_pricingYear</span>
                    <button class="btn-nav" @onclick="NextYear">&gt;</button>
                </div>
            </div>
            <div class="bd">
                @if (_loadingPricing)
                {
                    <div class="loading-indicator">Chargement des tarifs...</div>
                }
                else if (_pricingGrid is null)
                {
                    <div class="hint">
                        Aucune grille tarifaire pour @_pricingYear.
                        <button class="btn primary" style="margin-top:10px" @onclick="CreateDefaultGrid">
                            Créer la grille @_pricingYear
                        </button>
                    </div>
                }
                else
                {
                    @if (_pricingSuccess is not null)
                    {
                        <div class="alert-success">@_pricingSuccess</div>
                    }
                    @if (_pricingError is not null)
                    {
                        <div class="alert-error">@_pricingError</div>
                    }

                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Type de client</th>
                                <th>Prix / jour / personne</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in _editLines)
                            {
                                <tr>
                                    <td>@GetClientTypeLabel(line.ClientType)</td>
                                    <td>
                                        <input type="number" step="0.50" min="0"
                                               value="@line.Price"
                                               @onchange="e => OnPriceChanged(line.ClientType, e)"
                                               class="price-input" />
                                        <span class="price-unit">€</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div class="modal-actions">
                        <button class="btn" @onclick="ResetPricing">Annuler</button>
                        <button class="btn primary" @onclick="SavePricing" disabled="@_savingPricing">
                            @(_savingPricing ? "Enregistrement..." : "Enregistrer les tarifs")
                        </button>
                    </div>
                }
            </div>
        </div>
    }

    @if (_activeTab == "studios")
    {
        <div class="card">
            <div class="hd">
                <h2>Studios</h2>
                <span class="pill">Catalogue figé</span>
            </div>
            <div class="bd">
                @if (_loadingStudios)
                {
                    <div class="loading-indicator">Chargement des studios...</div>
                }
                else if (_studios is not null)
                {
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Nom</th>
                                <th>Capacité</th>
                                <th>Cuisine</th>
                                <th>Louable seul</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _studios)
                            {
                                <tr>
                                    <td><b>@s.Name</b></td>
                                    <td>@s.Capacity pers.</td>
                                    <td>
                                        <span class="badge @(s.HasKitchen ? "st-confirmed" : "")">
                                            @(s.HasKitchen ? "Oui" : "Non")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @(s.RentableAlone ? "st-confirmed" : "st-pending")">
                                            @(s.RentableAlone ? "Oui" : "Non")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="hint" style="margin-top:12px">
                        Le catalogue de studios est figé dans la configuration initiale. Contactez l'administrateur système pour toute modification.
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private string _activeTab = "pricing";

    private int _pricingYear = DateTime.Today.Year;
    private PricingGridDto? _pricingGrid;
    private List<EditablePricingLine> _editLines = [];
    private bool _loadingPricing = true;
    private bool _savingPricing;
    private string? _pricingSuccess;
    private string? _pricingError;

    private IReadOnlyList<StudioDto>? _studios;
    private bool _loadingStudios = true;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadPricingGrid(), LoadStudios());
    }

    private async Task LoadPricingGrid()
    {
        _loadingPricing = true;
        _pricingSuccess = null;
        _pricingError = null;

        _pricingGrid = await Mediator.Send(
            new PlanningLocation.Application.Queries.GetPricingGrid.GetPricingGridQuery(_pricingYear));

        if (_pricingGrid is not null)
        {
            _editLines = _pricingGrid.Lines
                .Select(l => new EditablePricingLine(l.ClientType, l.PricePerDayPerPerson))
                .ToList();
        }

        _loadingPricing = false;
    }

    private async Task LoadStudios()
    {
        _loadingStudios = true;
        _studios = await Mediator.Send(new PlanningLocation.Application.Queries.GetStudios.GetStudiosQuery());
        _loadingStudios = false;
    }

    private async Task PreviousYear()
    {
        _pricingYear--;
        await LoadPricingGrid();
    }

    private async Task NextYear()
    {
        _pricingYear++;
        await LoadPricingGrid();
    }

    private void OnPriceChanged(ClientType type, ChangeEventArgs e)
    {
        var line = _editLines.FirstOrDefault(l => l.ClientType == type);
        if (line is not null && decimal.TryParse(e.Value?.ToString(), out var price))
        {
            line.Price = price;
        }
    }

    private void ResetPricing()
    {
        if (_pricingGrid is not null)
        {
            _editLines = _pricingGrid.Lines
                .Select(l => new EditablePricingLine(l.ClientType, l.PricePerDayPerPerson))
                .ToList();
        }
        _pricingSuccess = null;
        _pricingError = null;
    }

    private async Task SavePricing()
    {
        _savingPricing = true;
        _pricingSuccess = null;
        _pricingError = null;

        try
        {
            var lines = _editLines
                .Select(l => new PlanningLocation.Application.Commands.UpdatePricingGrid.PricingLineInput(
                    l.ClientType, l.Price))
                .ToList();

            await Mediator.Send(
                new PlanningLocation.Application.Commands.UpdatePricingGrid.UpdatePricingGridCommand(
                    _pricingYear, lines));

            _pricingSuccess = "Grille tarifaire enregistrée.";
            await LoadPricingGrid();
        }
        catch (UnauthorizedAccessException)
        {
            _pricingError = "Vous devez être connecté pour effectuer cette action.";
        }
        catch (FluentValidation.ValidationException ex)
        {
            _pricingError = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
        catch (Exception ex)
        {
            _pricingError = ex.Message;
        }
        finally
        {
            _savingPricing = false;
        }
    }

    private async Task CreateDefaultGrid()
    {
        _savingPricing = true;
        try
        {
            var defaultLines = new List<PlanningLocation.Application.Commands.UpdatePricingGrid.PricingLineInput>
            {
                new(ClientType.Owner, 3.50m),
                new(ClientType.GuestWithPresence, 7.00m),
                new(ClientType.Acquaintance, 15.00m),
                new(ClientType.MobileHome, 12.00m),
                new(ClientType.Tent, 7.00m),
            };

            await Mediator.Send(
                new PlanningLocation.Application.Commands.UpdatePricingGrid.UpdatePricingGridCommand(
                    _pricingYear, defaultLines));

            await LoadPricingGrid();
        }
        catch (Exception ex)
        {
            _pricingError = ex.Message;
        }
        finally
        {
            _savingPricing = false;
        }
    }

    private string GetClientTypeLabel(ClientType type) => type switch
    {
        ClientType.Owner => "Propriétaire (et familles)",
        ClientType.GuestWithPresence => "Invités avec présence",
        ClientType.Acquaintance => "Connaissances",
        ClientType.MobileHome => "Mobil-home",
        ClientType.Tent => "Tente",
        _ => type.ToString()
    };

    private class EditablePricingLine(ClientType clientType, decimal price)
    {
        public ClientType ClientType { get; } = clientType;
        public decimal Price { get; set; } = price;
    }
}
