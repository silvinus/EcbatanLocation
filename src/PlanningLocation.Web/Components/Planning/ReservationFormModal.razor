@inject IMediator Mediator

<div class="modal-overlay" @onclick="OnCancel">
    <div class="modal-content modal-wide" role="dialog" aria-modal="true"
         aria-label="@(IsEdit ? "Modifier la réservation" : "Nouvelle réservation")" @onclick:stopPropagation="true">
        <div class="modal-hd">
            <h3>@(IsEdit ? "Modifier la réservation" : "Nouvelle réservation")</h3>
            <button class="x" @onclick="OnCancel">Fermer</button>
        </div>
        <div class="modal-bd">
            @if (_errorMessage is not null)
            {
                <div class="alert-error">@_errorMessage</div>
            }

            @if (_overlapWarning)
            {
                <div class="alert-error">
                    ⚠ Ce studio est déjà réservé sur ces dates. Veuillez choisir un autre créneau.
                </div>
            }

            <div class="grid">
                <div class="field">
                    <label>Studio</label>
                    <select value="@_studioId" @onchange="OnStudioChanged">
                        <option value="">-- Choisir un studio --</option>
                        @foreach (var s in Studios)
                        {
                            <option value="@s.Id">@s.Name (@s.Capacity pers.@(s.HasKitchen ? ", cuisine" : "")@(!s.RentableAlone ? ", non louable seul" : ""))</option>
                        }
                    </select>
                    @if (!string.IsNullOrEmpty(_studioId) && _selectedStudio is not null && !_selectedStudio.RentableAlone)
                    {
                        <div class="field-hint warn">Ce studio ne peut être loué qu'avec un studio indépendant sur les mêmes dates.</div>
                    }
                </div>

                <div class="row">
                    <div class="field">
                        <label>Date d'arrivée</label>
                        <input type="date" value="@_startDate.ToString("yyyy-MM-dd")"
                               @onchange="OnStartDateChanged" />
                    </div>
                    <div class="field">
                        <label>Date de départ</label>
                        <input type="date" value="@_endDate.ToString("yyyy-MM-dd")"
                               @onchange="OnEndDateChanged" />
                    </div>
                </div>

                @if (_startDate < _endDate)
                {
                    <div class="hint">@NightCount nuit(s)</div>
                }
                @if (_startDate >= _endDate)
                {
                    <div class="field-hint warn">La date de départ doit être après la date d'arrivée.</div>
                }

                <div class="field">
                    <label>Nom du locataire</label>
                    <input @bind="_tenantName" placeholder="Nom complet du locataire" />
                </div>

                @* Person lines *@
                <div class="field">
                    <label>Personnes</label>
                    <div class="person-lines">
                        @for (int i = 0; i < _personLines.Count; i++)
                        {
                            var index = i;
                            var line = _personLines[index];
                            <div class="person-line-row">
                                <div class="field" style="flex:2">
                                    <select value="@line.ClientType" @onchange="e => OnLineTypeChanged(index, e)" disabled="@_isExclusiveType">
                                        @if (_isExclusiveType)
                                        {
                                            <option value="@line.ClientType">@GetClientTypeLabel(line.ClientType)</option>
                                        }
                                        else
                                        {
                                            <option value="@ClientType.Owner">Propriétaire</option>
                                            <option value="@ClientType.GuestWithPresence">Invité avec présence</option>
                                            <option value="@ClientType.Acquaintance">Connaissance</option>
                                        }
                                    </select>
                                </div>
                                <div class="field" style="flex:1">
                                    <input type="number" min="0" value="@line.AdultCount"
                                           placeholder="Ad."
                                           @onchange="e => OnLineAdultChanged(index, e)" />
                                </div>
                                <div class="field" style="flex:1">
                                    <input type="number" min="0" value="@line.ChildrenCount"
                                           placeholder="Enf."
                                           @onchange="e => OnLineChildrenChanged(index, e)" />
                                </div>
                                @if (!_isExclusiveType && _personLines.Count > 1)
                                {
                                    <button class="x-small" @onclick="() => RemoveLine(index)" title="Supprimer">×</button>
                                }
                            </div>
                        }
                    </div>
                    @if (!_isExclusiveType)
                    {
                        <button class="btn" style="margin-top:6px;font-size:12px;padding:6px 10px" @onclick="AddLine">+ Ajouter un type</button>
                    }
                </div>

                <div class="hint">
                    <span style="margin-right:12px">Adultes</span> <span style="margin-right:12px">Enfants &lt;3 ans</span>
                </div>

                @if (_selectedStudio is not null && TotalPersons > _selectedStudio.Capacity)
                {
                    <div class="field-hint warn">
                        Capacité dépassée : @TotalPersons personne(s) pour @_selectedStudio.Capacity place(s) max.
                    </div>
                }

                @if (_estimatedAmount.HasValue)
                {
                    <div class="estimation">
                        <span class="label">Montant estimé</span>
                        <span class="amount">@_estimatedAmount.Value.ToString("N2") €</span>
                    </div>
                }

                @if (_checkingOverlap)
                {
                    <div class="hint">Vérification de la disponibilité…</div>
                }
            </div>

            <div class="modal-actions">
                <button class="btn" @onclick="OnCancel">Annuler</button>
                <button class="btn primary" @onclick="Save" disabled="@(_saving || _overlapWarning)">
                    @(_saving ? "Enregistrement..." : "Enregistrer")
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<StudioDto> Studios { get; set; } = [];
    [Parameter, EditorRequired] public Guid CurrentOwnerId { get; set; }
    [Parameter] public ReservationDetailDto? EditReservation { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private bool IsEdit => EditReservation is not null;

    private string _studioId = "";
    private DateOnly _startDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly _endDate = DateOnly.FromDateTime(DateTime.Today.AddDays(1));
    private string _tenantName = "";
    private List<PersonLineState> _personLines = [new(ClientType.Owner, 1, 0)];
    private decimal? _estimatedAmount;
    private string? _errorMessage;
    private bool _saving;
    private bool _overlapWarning;
    private bool _checkingOverlap;
    private StudioDto? _selectedStudio;
    private bool _isExclusiveType;

    private int NightCount => _endDate.DayNumber - _startDate.DayNumber;
    private int TotalPersons => _personLines.Sum(l => l.AdultCount + l.ChildrenCount);

    private CancellationTokenSource? _overlapCts;

    private class PersonLineState(ClientType clientType, int adultCount, int childrenCount)
    {
        public ClientType ClientType { get; set; } = clientType;
        public int AdultCount { get; set; } = adultCount;
        public int ChildrenCount { get; set; } = childrenCount;
    }

    protected override void OnParametersSet()
    {
        if (EditReservation is not null)
        {
            _studioId = EditReservation.Studio.Id.ToString();
            _startDate = EditReservation.StartDate;
            _endDate = EditReservation.EndDate;
            _tenantName = EditReservation.TenantName;
            _personLines = EditReservation.PersonLines
                .Select(pl => new PersonLineState(pl.ClientType, pl.AdultCount, pl.ChildrenUnder3Count))
                .ToList();
            _estimatedAmount = EditReservation.EstimatedAmount;
            _selectedStudio = Studios.FirstOrDefault(s => s.Id == EditReservation.Studio.Id);
            UpdateExclusiveType();
        }
    }

    private void UpdateExclusiveType()
    {
        if (_selectedStudio is null)
        {
            _isExclusiveType = false;
            return;
        }

        var name = _selectedStudio.Name.ToLowerInvariant();
        if (name.Contains("mobil"))
        {
            _isExclusiveType = true;
            foreach (var line in _personLines) line.ClientType = ClientType.MobileHome;
            if (_personLines.Count > 1)
                _personLines = [_personLines[0]];
        }
        else if (name.Contains("tente") || name.Contains("emplacement"))
        {
            _isExclusiveType = true;
            foreach (var line in _personLines) line.ClientType = ClientType.Tent;
            if (_personLines.Count > 1)
                _personLines = [_personLines[0]];
        }
        else
        {
            _isExclusiveType = false;
            foreach (var line in _personLines)
            {
                if (line.ClientType is ClientType.MobileHome or ClientType.Tent)
                    line.ClientType = ClientType.Owner;
            }
        }
    }

    private async Task OnStudioChanged(ChangeEventArgs e)
    {
        _studioId = e.Value?.ToString() ?? "";
        _selectedStudio = Guid.TryParse(_studioId, out var sid)
            ? Studios.FirstOrDefault(s => s.Id == sid)
            : null;
        UpdateExclusiveType();
        await RefreshEstimateAndOverlap();
    }

    private async Task OnStartDateChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var d))
            _startDate = d;
        await RefreshEstimateAndOverlap();
    }

    private async Task OnEndDateChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var d))
            _endDate = d;
        await RefreshEstimateAndOverlap();
    }

    private async Task OnLineTypeChanged(int index, ChangeEventArgs e)
    {
        if (Enum.TryParse<ClientType>(e.Value?.ToString(), out var ct))
            _personLines[index].ClientType = ct;
        await EstimateAmount();
    }

    private async Task OnLineAdultChanged(int index, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var n))
            _personLines[index].AdultCount = Math.Max(0, n);
        await EstimateAmount();
    }

    private async Task OnLineChildrenChanged(int index, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var n))
            _personLines[index].ChildrenCount = Math.Max(0, n);
        await EstimateAmount();
    }

    private void AddLine()
    {
        var usedTypes = _personLines.Select(l => l.ClientType).ToHashSet();
        var nextType = new[] { ClientType.Owner, ClientType.GuestWithPresence, ClientType.Acquaintance }
            .FirstOrDefault(t => !usedTypes.Contains(t), ClientType.Owner);
        _personLines.Add(new PersonLineState(nextType, 1, 0));
    }

    private async Task RemoveLine(int index)
    {
        _personLines.RemoveAt(index);
        await EstimateAmount();
    }

    private async Task RefreshEstimateAndOverlap()
    {
        await Task.WhenAll(EstimateAmount(), CheckOverlap());
    }

    private async Task EstimateAmount()
    {
        if (_startDate >= _endDate || _personLines.Sum(l => l.AdultCount) < 1)
        {
            _estimatedAmount = null;
            return;
        }

        try
        {
            var lines = _personLines
                .Select(l => new PersonLineDto(l.ClientType, l.AdultCount, l.ChildrenCount))
                .ToList();
            _estimatedAmount = await Mediator.Send(
                new PlanningLocation.Application.Queries.EstimateAmount.EstimateAmountQuery(
                    _startDate, _endDate, lines));
        }
        catch
        {
            _estimatedAmount = null;
        }
    }

    private async Task CheckOverlap()
    {
        _overlapCts?.Cancel();
        _overlapCts = new CancellationTokenSource();
        var token = _overlapCts.Token;

        if (!Guid.TryParse(_studioId, out var studioId) || studioId == Guid.Empty
            || _startDate >= _endDate)
        {
            _overlapWarning = false;
            return;
        }

        _checkingOverlap = true;
        StateHasChanged();

        try
        {
            await Task.Delay(300, token);

            var hasOverlap = await Mediator.Send(
                new PlanningLocation.Application.Queries.CheckOverlap.CheckOverlapQuery(
                    studioId, _startDate, _endDate,
                    IsEdit ? EditReservation!.Id : null),
                token);

            _overlapWarning = hasOverlap;
        }
        catch (OperationCanceledException) { }
        catch
        {
            _overlapWarning = false;
        }
        finally
        {
            _checkingOverlap = false;
        }
    }

    private async Task Save()
    {
        _errorMessage = null;
        _saving = true;

        try
        {
            if (!Guid.TryParse(_studioId, out var studioId) || studioId == Guid.Empty)
            {
                _errorMessage = "Veuillez sélectionner un studio.";
                return;
            }

            if (string.IsNullOrWhiteSpace(_tenantName))
            {
                _errorMessage = "Veuillez saisir le nom du locataire.";
                return;
            }

            if (_startDate >= _endDate)
            {
                _errorMessage = "La date de fin doit être après la date de début.";
                return;
            }

            if (_personLines.Sum(l => l.AdultCount) < 1)
            {
                _errorMessage = "Au moins 1 adulte est requis.";
                return;
            }

            if (_overlapWarning)
            {
                _errorMessage = "Impossible d'enregistrer : le studio est déjà réservé sur ces dates.";
                return;
            }

            var personLineDtos = _personLines
                .Where(l => l.AdultCount > 0 || l.ChildrenCount > 0)
                .Select(l => new PersonLineDto(l.ClientType, l.AdultCount, l.ChildrenCount))
                .ToList();

            if (IsEdit)
            {
                await Mediator.Send(new PlanningLocation.Application.Commands.UpdateReservation.UpdateReservationCommand(
                    EditReservation!.Id, studioId, _startDate, _endDate,
                    _tenantName.Trim(), personLineDtos));
            }
            else
            {
                await Mediator.Send(new PlanningLocation.Application.Commands.CreateReservation.CreateReservationCommand(
                    studioId, CurrentOwnerId, _startDate, _endDate,
                    _tenantName.Trim(), personLineDtos));
            }

            await OnSaved.InvokeAsync();
        }
        catch (UnauthorizedAccessException)
        {
            _errorMessage = "Vous devez être connecté pour effectuer cette action.";
        }
        catch (FluentValidation.ValidationException ex)
        {
            _errorMessage = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private static string GetClientTypeLabel(ClientType type) => type switch
    {
        ClientType.Owner => "Propriétaire",
        ClientType.GuestWithPresence => "Invité avec présence",
        ClientType.Acquaintance => "Connaissance",
        ClientType.MobileHome => "Mobil-home",
        ClientType.Tent => "Tente",
        _ => ""
    };
}
