<div class="row">
    <div class="field">
        <label>Mois</label>
        <input type="month" value="@($"{Year}-{Month:D2}")" @onchange="OnMonthInput" />
    </div>
    <div class="field">
        <label>Studio</label>
        <select value="@SelectedStudioId?.ToString()" @onchange="OnStudioInput">
            <option value="">Tous</option>
            @if (Studios is not null)
            {
                @foreach (var s in Studios)
                {
                    <option value="@s.Id">@s.Name</option>
                }
            }
        </select>
    </div>
</div>

<div class="row">
    <div class="field">
        <label>Statut</label>
        <select value="@SelectedStatus?.ToString()" @onchange="OnStatusInput">
            <option value="">Tous</option>
            <option value="Pending">Demande</option>
            <option value="Accepted">Accept&#233;e</option>
            <option value="Confirmed">Confirm&#233;e</option>
        </select>
    </div>
    <div class="field">
        <label>Propri&#233;taire</label>
        <select value="@SelectedOwnerId?.ToString()" @onchange="OnOwnerInput">
            <option value="">Tous</option>
            @if (Owners is not null)
            {
                @foreach (var o in Owners)
                {
                    <option value="@o.Id">@o.Name</option>
                }
            }
        </select>
    </div>
</div>

<div class="sep"></div>

@if (RangeStart.HasValue && RangeEnd.HasValue && RangeOccupation is not null)
{
    <div class="range-indicator">
        <div class="range-header">
            <span class="range-label">P&#233;riode : @RangeStart.Value.ToString("dd/MM") &#8594; @RangeEnd.Value.ToString("dd/MM")</span>
            <button class="x-small" @onclick="OnClearRange" title="R&#233;initialiser">&#x2715;</button>
        </div>
    </div>

    <div class="kpi">
        <div class="box">
            <div class="big">@RangeOccupation.AverageOccupancyRate<span class="unit">%</span></div>
            <div class="lab">Taux moyen (@RangeOccupation.DaysInRange j.)</div>
        </div>
        <div class="box">
            <div class="big">@RangeOccupation.AverageOccupiedPlaces<span class="unit"> / @RangeOccupation.TotalCapacity</span></div>
            <div class="lab">Places moy. occup&#233;es</div>
        </div>
    </div>

    <div class="sep"></div>
}
else if (RangeStart.HasValue && !RangeEnd.HasValue)
{
    <div class="range-indicator">
        <div class="range-header">
            <span class="range-label hint">D&#233;but : @RangeStart.Value.ToString("dd/MM") — cliquez un 2e jour</span>
            <button class="x-small" @onclick="OnClearRange" title="Annuler">&#x2715;</button>
        </div>
    </div>
}

<div class="kpi">
    <div class="box">
        @if (Occupation is not null)
        {
            <div class="big">@Occupation.OccupiedPlaces / @Occupation.TotalCapacity</div>
        }
        else
        {
            <div class="big">-- / --</div>
        }
        <div class="lab">Places occup&#233;es@(SelectedDate.HasValue ? $" ({SelectedDate.Value:dd/MM})" : " (auj.)")</div>
    </div>
    <div class="box">
        @if (Occupation is not null)
        {
            <div class="big">@Occupation.OccupiedStudios</div>
        }
        else
        {
            <div class="big">--</div>
        }
        <div class="lab">Studios occup&#233;s@(SelectedDate.HasValue ? $" ({SelectedDate.Value:dd/MM})" : " (auj.)")</div>
    </div>
</div>

<div class="sep"></div>

<div class="hint">
    <b>S&#233;lection plage</b>
    <div class="chips" style="margin-top:8px">
        <span class="chip muted">1er clic = d&#233;but</span>
        <span class="chip muted">2e clic = fin</span>
    </div>
</div>

<div class="sep"></div>

<div class="hint">
    <b>L&#233;gende statuts</b>
    <div class="legend" style="margin-top:8px">
        <div class="legend-item"><span class="dot" style="background:var(--warn)"></span> Demande</div>
        <div class="legend-item"><span class="dot" style="background:var(--brand)"></span> Accept&#233;e</div>
        <div class="legend-item"><span class="dot" style="background:var(--ok)"></span> Confirm&#233;e</div>
    </div>
</div>

<div class="sep"></div>

<div class="hint">
    <b>Rappels m&#233;tier</b>
    <div class="chips" style="margin-top:8px">
        <span class="chip">Un studio = libre ou occup&#233;</span>
        <span class="chip">Pas de location partielle</span>
        <span class="chip muted">Studios fig&#233;s</span>
        <span class="chip muted">Tarifs versionn&#233;s / ann&#233;e</span>
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<StudioDto>? Studios { get; set; }
    [Parameter] public IReadOnlyList<OwnerDto>? Owners { get; set; }
    [Parameter] public int Year { get; set; }
    [Parameter] public int Month { get; set; }
    [Parameter] public Guid? SelectedStudioId { get; set; }
    [Parameter] public ReservationStatus? SelectedStatus { get; set; }
    [Parameter] public Guid? SelectedOwnerId { get; set; }
    [Parameter] public DateOnly? SelectedDate { get; set; }
    [Parameter] public DateOnly? RangeStart { get; set; }
    [Parameter] public DateOnly? RangeEnd { get; set; }
    [Parameter] public OccupationJourDto? Occupation { get; set; }
    [Parameter] public OccupationRangeDto? RangeOccupation { get; set; }
    [Parameter] public EventCallback<(int year, int month)> OnYearMonthChanged { get; set; }
    [Parameter] public EventCallback<Guid?> OnStudioChanged { get; set; }
    [Parameter] public EventCallback<ReservationStatus?> OnStatusChanged { get; set; }
    [Parameter] public EventCallback<Guid?> OnOwnerChanged { get; set; }
    [Parameter] public EventCallback OnClearRange { get; set; }

    private async Task OnMonthInput(ChangeEventArgs e)
    {
        if (e.Value is string val && DateOnly.TryParse(val + "-01", out var date))
        {
            await OnYearMonthChanged.InvokeAsync((date.Year, date.Month));
        }
    }

    private async Task OnStudioInput(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        Guid? id = string.IsNullOrEmpty(val) ? null : Guid.Parse(val);
        await OnStudioChanged.InvokeAsync(id);
    }

    private async Task OnStatusInput(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        ReservationStatus? status = string.IsNullOrEmpty(val) ? null : Enum.Parse<ReservationStatus>(val);
        await OnStatusChanged.InvokeAsync(status);
    }

    private async Task OnOwnerInput(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        Guid? id = string.IsNullOrEmpty(val) ? null : Guid.Parse(val);
        await OnOwnerChanged.InvokeAsync(id);
    }
}
