@{
    var daysInMonth = DateTime.DaysInMonth(Year, Month);
    var today = DateOnly.FromDateTime(DateTime.Today);
    var monthStart = new DateOnly(Year, Month, 1);
    var monthEnd = new DateOnly(Year, Month, daysInMonth);
}

<table aria-label="planning">
    <thead>
        <tr>
            <th class="studio-col">Studio</th>
            @for (int d = 1; d <= daysInMonth; d++)
            {
                var date = new DateOnly(Year, Month, d);
                var isToday = date == today;
                var isSelected = date == SelectedDate;
                var isWeekend = date.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                var dayNum = d;
                <th class="day-col @(isToday ? "today" : "") @(isSelected ? "selected" : "") @(IsInRange(date) ? "in-range" : "")">
                    <span class="day-header @(isToday ? "today" : "") @(isWeekend ? "weekend" : "")"
                          @onclick="() => OnDayClicked(date)">
                        @dayNum
                    </span>
                </th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var studioPlan in Planning.Studios)
        {
            var spans = BuildSpans(studioPlan.Reservations, monthStart, monthEnd, daysInMonth);

            <tr>
                <td class="studio-col">
                    <div class="studio-name">@studioPlan.Studio.Name</div>
                    <div class="studio-meta">
                        @if (studioPlan.Studio.HasKitchen) { <span>Cuisine</span> }
                        else { <span>Sans cuisine</span> }
                        &bull; @studioPlan.Studio.Capacity pl.
                        @if (!studioPlan.Studio.RentableAlone) { <span>&bull; <b>Non louable seul</b></span> }
                    </div>
                </td>
                @for (int d = 1; d <= daysInMonth; d++)
                {
                    var date = new DateOnly(Year, Month, d);
                    var isToday = date == today;
                    var isSelected = date == SelectedDate;

                    var inRange = IsInRange(date);
                    var span = spans.FirstOrDefault(s => s.StartDay == d);
                    if (span is not null)
                    {
                        var res = span.Reservation;
                        var startsBeforeMonth = res.StartDate < monthStart;
                        var endsAfterMonth = res.EndDate > monthEnd.AddDays(1);
                        var roundLeft = !startsBeforeMonth;
                        var roundRight = !endsAfterMonth;

                        <td colspan="@span.ColSpan"
                            class="day-col bar-cell @(isToday ? "today" : "") @(isSelected ? "selected" : "") @(inRange ? "in-range" : "")"
                            @onclick="() => OnReservationClick(res.Id)">
                            <div class="booking-span @GetStatusClass(res.Status) @(roundLeft ? "round-left" : "") @(roundRight ? "round-right" : "")">
                                <span class="span-name">@res.TenantName</span>
                                <span class="span-owner">@res.OwnerName</span>
                                <span class="span-count">@res.PersonLines.Sum(l => l.AdultCount) ad.@(res.PersonLines.Sum(l => l.ChildrenUnder3Count) > 0 ? $" +{res.PersonLines.Sum(l => l.ChildrenUnder3Count)}" : "")</span>
                            </div>
                        </td>
                    }
                    else if (!spans.Any(s => d > s.StartDay && d < s.StartDay + s.ColSpan))
                    {
                        <td class="day-col @(isToday ? "today" : "") @(isSelected ? "selected" : "") @(inRange ? "in-range" : "")"
                            @onclick="() => OnDayClicked(date)">
                        </td>
                    }
                }
            </tr>
        }
    </tbody>
</table>

@code {
    [Parameter, EditorRequired] public MonthlyPlanningDto Planning { get; set; } = default!;
    [Parameter] public int Year { get; set; }
    [Parameter] public int Month { get; set; }
    [Parameter] public DateOnly? SelectedDate { get; set; }
    [Parameter] public DateOnly? RangeStart { get; set; }
    [Parameter] public DateOnly? RangeEnd { get; set; }
    [Parameter] public EventCallback<DateOnly> OnDaySelected { get; set; }
    [Parameter] public EventCallback<Guid> OnReservationClicked { get; set; }

    private bool IsInRange(DateOnly date)
    {
        if (RangeStart is null) return false;
        if (RangeEnd is null) return date == RangeStart;
        return date >= RangeStart && date <= RangeEnd;
    }

    private record SpanInfo(int StartDay, int ColSpan, ReservationPlanningDto Reservation);

    private List<SpanInfo> BuildSpans(
        IReadOnlyList<ReservationPlanningDto> reservations,
        DateOnly monthStart, DateOnly monthEnd, int daysInMonth)
    {
        var result = new List<SpanInfo>();

        foreach (var res in reservations)
        {
            var visibleStart = res.StartDate < monthStart ? monthStart : res.StartDate;
            var visibleEnd = res.EndDate > monthEnd.AddDays(1) ? monthEnd.AddDays(1) : res.EndDate;

            if (visibleStart > monthEnd || visibleEnd <= monthStart)
                continue;

            var startDay = visibleStart.Day;
            var endDay = visibleEnd <= monthEnd ? visibleEnd.Day : daysInMonth + 1;
            var colSpan = endDay - startDay;

            if (colSpan > 0)
                result.Add(new SpanInfo(startDay, colSpan, res));
        }

        return result;
    }

    private string GetStatusClass(ReservationStatus status) => status switch
    {
        ReservationStatus.Pending => "st-pending",
        ReservationStatus.Accepted => "st-accepted",
        ReservationStatus.Confirmed => "st-confirmed",
        _ => ""
    };

    private async Task OnDayClicked(DateOnly date)
    {
        await OnDaySelected.InvokeAsync(date);
    }

    private async Task OnReservationClick(Guid id)
    {
        await OnReservationClicked.InvokeAsync(id);
    }
}
